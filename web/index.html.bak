       {k:["empresa","recrutador","contratar","publicar","empregador"],a:"As empresas chegam a candidatos já filtrados por compatibilidade, e você chega a vagas onde realmente tem chances. Todo o produto é construído em torno da sua experiência como candidato."},
       {k:["extensao","extensão","chrome","navegador","instalar"],a:"Na versão completa, uma extensão do Chrome preenche os formulários em cada site de emprego. Nesta demo o processo é simulado."},
       {k:["dominio","domínio","url","proprio",".com"],a:"Sim, dá para conectar um domínio próprio (ex.: matchapply.com). Hoje ele vive em matchapply.netlify.app."},
       {k:["conta","cadastro","login","sincroniz","salvar","dispositivo"],a:"Na versão completa você vai poder criar uma conta e sincronizar o perfil entre dispositivos. Nesta demo os dados ficam só no seu navegador."},
       {k:["vagas reais","tempo real","de onde","fontes","reais"],a:"Em produção as vagas vêm de fontes reais (portais e ATS como Greenhouse ou Lever). Na demo são exemplos."},
       {k:["quem","criou","fez","fundador","atras","atrás"],a:"O MatchApply é um projeto em construção, pensado para que procurar emprego seja mais rápido e com critério."},
       {k:["contato","falar","suporte","humano","ajuda"],a:"Deixe as suas dúvidas aqui; na versão completa haverá suporte e um assistente com IA para perguntas mais abertas."},
       {k:["revisar","confirmar","envia sozinho","envio automatico","seguro"],a:"Nunca enviamos uma candidatura sem a sua confirmação. A candidatura automática prepara tudo e você revisa antes do envio final."},
       {k:["carta","apresentacao","apresentação","cover"],a:"Podemos gerar uma carta de apresentação a partir do seu perfil; você sempre revisa antes de enviar."} ]
};
/* --- estado del chat: persiste en memoria + localStorage, sobrevive al cambio de idioma --- */
var BOT_HIST=[];            // [{who:'me'|'bot', text?, key?, kb?}]
var _botReplyTimer=null;
let botStarted=false, botDragged=false;
function loadChat(){ try{ BOT_HIST=JSON.parse(localStorage.getItem('ma_chat')||'[]')||[]; }catch(e){ BOT_HIST=[]; } if(!Array.isArray(BOT_HIST)) BOT_HIST=[]; }
function saveChat(){ try{ localStorage.setItem('ma_chat',JSON.stringify(BOT_HIST.slice(-80))); }catch(e){} }
/* el texto se resuelve en el idioma activo: los mensajes del usuario quedan tal cual,
   los del bot se re-traducen por clave (key) o por indice de la base de conocimiento (kb) */
function botTextOf(m){
  if(!m) return '';
  if(m.who==='me') return m.text||'';
  if(m.kb!=null){ var kb=BOT_KB[lang]||BOT_KB.es; var e=kb[m.kb]; if(e&&e.a) return e.a; }
  if(m.key) return t(m.key);
  return m.text||'';
}
function appendBubble(text,who){ var m=document.getElementById('botMsgs'); if(!m) return;
  var d=document.createElement('div'); d.className='bmsg '+who; d.textContent=text; m.appendChild(d); m.scrollTop=m.scrollHeight; }
function renderBotMsgs(){ var m=document.getElementById('botMsgs'); if(!m) return; m.innerHTML='';
  BOT_HIST.forEach(function(x){ appendBubble(botTextOf(x),x.who); }); m.scrollTop=m.scrollHeight; }
function botPush(msg){ BOT_HIST.push(msg); saveChat(); appendBubble(botTextOf(msg),msg.who); }
function clearChat(){
  clearTimeout(_botReplyTimer);                       // una respuesta en camino no debe resucitar el chat viejo
  BOT_HIST.length=0;                                  // vacia el array in-place (no deja referencias colgadas)
  BOT_HIST=[];
  try{ localStorage.removeItem('ma_chat'); }catch(e){}
  try{ if(window.sessionStorage) sessionStorage.removeItem('ma_chat'); }catch(e){}
  botStarted=false;
  var m=document.getElementById('botMsgs');
  if(m){ m.innerHTML=''; m.scrollTop=0; }             // pantalla limpia de verdad
  var i=document.getElementById('botInput'); if(i) i.value='';
  /* recien ahora el bot arranca de cero, como si abrieras el chat por primera vez */
  botStarted=true;
  botPush({who:'bot',key:'bot_hi'});
  renderBotSugg();
  if(i) i.focus();
}
var _botCloseTimer=null;
function toggleBot(open){
  var p=document.getElementById('botPanel'); if(!p) return;
  var isOpen=p.classList.contains('open') && !p.classList.contains('closing');
  var willOpen = (open===undefined) ? !isOpen : open;

  if(willOpen){
    clearTimeout(_botCloseTimer);
    p.classList.remove('closing');                 // si venia cerrandose, se recupera al vuelo
    p.classList.add('open');
    positionBotPanel(); botStarted=true;
    if(!BOT_HIST.length){ botPush({who:'bot',key:'bot_hi'}); } else { renderBotMsgs(); }
    renderBotSugg();
    setTimeout(function(){ var i=document.getElementById('botInput'); if(i) i.focus(); },50);
    return;
  }

  /* cierre: primero la animacion de salida, recien despues se oculta del DOM */
  if(!p.classList.contains('open') || p.classList.contains('closing')) return;
  p.classList.add('closing');
  var btn=document.getElementById('botBtn');
  if(btn){ btn.classList.remove('pulled'); void btn.offsetWidth; btn.classList.add('pulled'); }  // el boton "recibe" el panel
  var done=function(){
    clearTimeout(_botCloseTimer);
    p.classList.remove('open','closing');
    p.removeEventListener('animationend',done);
  };
  p.addEventListener('animationend',done);
  _botCloseTimer=setTimeout(done,340);             // red de seguridad si no dispara animationend
}
function positionBotPanel(){ const b=document.getElementById('botBtn'); const p=document.getElementById('botPanel'); const r=b.getBoundingClientRect();
  const w=Math.min(340,window.innerWidth-32); let left=r.right-w; let top=r.top-p.offsetHeight-10;
  if(top<10){ top=r.bottom+10; } if(left<10) left=10; if(left+w>window.innerWidth-10) left=window.innerWidth-10-w;
  p.style.right='auto'; p.style.bottom='auto'; p.style.left=left+'px'; p.style.top=Math.max(10,top)+'px'; }
function renderBotSugg(){ var el=document.getElementById('botSugg'); if(!el) return;
  el.innerHTML=['bot_s1','bot_s2','bot_s3'].map(function(k){return '<button onclick="botAsk(this.textContent)">'+t(k)+'</button>';}).join('')+
    (BOT_HIST.some(function(m){ return m.who==='me'; })
      ? '<button onclick="clearChat()" title="'+t('chat_clear')+'" style="color:var(--ink-3);background:var(--panel);border-color:var(--border-2)">'+t('chat_clear')+'</button>'
      : ''); }
function botMsg(text,who){ botPush({who:who,text:text}); }
function botReply(q){ const p=' '+stripAccents(q.toLowerCase())+' ';
  if(/\b(hola|holaa|hi|hello|hey|buenas|buenos dias|bonjour|salut|coucou|ola|oi)\b/.test(p)) return {who:'bot',key:'bot_hi'};
  if(/\b(gracias|thanks|thank you|thx|merci|obrigado|obrigada)\b/.test(p)) return {who:'bot',key:'bot_thanks'};
  const kb=BOT_KB[lang]||BOT_KB.es; var bi=-1,bestScore=0;
  for(var i=0;i<kb.length;i++){ var sc=0; for(var j=0;j<kb[i].k.length;j++){ if(p.indexOf(stripAccents(kb[i].k[j]))>=0) sc++; } if(sc>bestScore){ bestScore=sc; bi=i; } }
  return bi>=0 ? {who:'bot',kb:bi} : {who:'bot',key:'bot_fallback'}; }
function botAsk(text){
  botPush({who:'me',text:text}); renderBotSugg();
  clearTimeout(_botReplyTimer);
  _botReplyTimer=setTimeout(function(){ botPush(botReply(text)); renderBotSugg(); },350);
}
function botSend(){ const inp=document.getElementById('botInput'); const v=inp.value.trim(); if(!v) return; inp.value=''; botAsk(v); }
/* draggable button */
(function(){ const btn=document.getElementById('botBtn'); let sx,sy,ox,oy,moved=false,dragging=false;
  function down(e){ dragging=true; moved=false; const pt=e.touches?e.touches[0]:e; sx=pt.clientX; sy=pt.clientY; const r=btn.getBoundingClientRect(); ox=r.left; oy=r.top; document.addEventListener('pointermove',move); document.addEventListener('pointerup',up); e.preventDefault(); }
  function move(e){ if(!dragging) return; const pt=e; const dx=pt.clientX-sx, dy=pt.clientY-sy; if(Math.abs(dx)+Math.abs(dy)>5) moved=true; let nl=ox+dx, nt=oy+dy; nl=Math.max(6,Math.min(window.innerWidth-64,nl)); nt=Math.max(6,Math.min(window.innerHeight-64,nt)); btn.style.left=nl+'px'; btn.style.top=nt+'px'; btn.style.right='auto'; btn.style.bottom='auto'; if(document.getElementById('botPanel').classList.contains('open')) positionBotPanel(); }
  function up(){ dragging=false; document.removeEventListener('pointermove',move); document.removeEventListener('pointerup',up); if(!moved){ toggleBot(); } }
  btn.addEventListener('pointerdown',down);
})();

/* ============ language apply ============ */
function applyI18n(){
  document.documentElement.lang=lang;
  document.querySelectorAll('[data-i18n]').forEach(function(el){ el.textContent=t(el.getAttribute('data-i18n')); });
  document.querySelectorAll('[data-i18n-ph]').forEach(function(el){ el.setAttribute('placeholder',t(el.getAttribute('data-i18n-ph'))); });
  const lbl=document.getElementById('analyzeLabel'); if(lbl){ lbl.textContent = analyzing? t('m_analyzing') : (analyzed? t('m_again') : t('m_analyze')); }
  fillJobSelects(); renderChips(); render();
  if(typeof updateFocusLabel==='function') updateFocusLabel();
  if(!document.getElementById('tab-adapter').classList.contains('hidden')) renderAdapter();
  if(!document.getElementById('tab-analysis').classList.contains('hidden')) renderAnalysis();
  if(!document.getElementById('tab-role').classList.contains('hidden')) renderRole();
}
function markLang(){ document.querySelectorAll('#langMenu button').forEach(function(b){ b.classList.toggle('active',b.dataset.l===lang); }); }
function updateLangBtn(){ var c=document.getElementById('langCode'); if(c) c.textContent=lang; var b=document.getElementById('langBtn'); if(b) b.setAttribute('aria-expanded', document.getElementById('langMenu').classList.contains('open')?'true':'false'); }
function toggleLangMenu(e){ if(e) e.stopPropagation();
  var m=document.getElementById('langMenu'), w=document.getElementById('lang');
  var open=!m.classList.contains('open'); m.classList.toggle('open',open); if(w) w.classList.toggle('open',open); updateLangBtn(); }
function closeLangMenu(){ var m=document.getElementById('langMenu'), w=document.getElementById('lang');
  if(m) m.classList.remove('open'); if(w) w.classList.remove('open'); updateLangBtn(); }
document.addEventListener('click', function(e){ var l=document.getElementById('lang'); if(l && !l.contains(e.target)) closeLangMenu(); });
document.addEventListener('keydown', function(e){ if(e.key==='Escape') closeLangMenu(); });
/* cambio de idioma: traduce TODO (landing, herramientas, CV) y NO reinicia el chat */
function setLang(l){ if(!I18N[l]) return; lang=l; try{ localStorage.setItem('ma_lang',l); }catch(e){}
  closeLangMenu(); document.body.classList.add('lang-swap');
  markLang(); updateLangBtn(); cvRelang(); applyI18n();
  renderBotMsgs(); renderBotSugg();                  // se re-traduce el entorno, el historial se conserva
  if(typeof updateAccountUI==='function') updateAccountUI();
  setTimeout(function(){ document.body.classList.remove('lang-swap'); },40); }

/* ============ init ============ */
/* ===== Cuenta / Plan / Premium (simulación front, backend real aparte) ===== */
var USER=null;
function loadUser(){ try{ USER=JSON.parse(localStorage.getItem('ma_user')||'null'); }catch(e){ USER=null; } }
function saveUser(){ try{ localStorage.setItem('ma_user',JSON.stringify(USER)); }catch(e){} }
function isLogged(){ return !!USER; }
function isPremium(){ return !!(USER&&USER.plan==='premium'); }
function dayKey(){ return new Date().toISOString().slice(0,10); }
function dailyLimit(){ return isPremium()?30:5; }
function resetIfNewDay(){ if(USER&&USER.day!==dayKey()){ USER.day=dayKey(); USER.used=0; saveUser(); } }
function creditsLeft(){ resetIfNewDay(); return USER?Math.max(0,dailyLimit()-USER.used):dailyLimit(); }
function useCredit(){ if(!USER) return false; resetIfNewDay(); if(USER.used>=dailyLimit()) return false; USER.used++; saveUser(); updateAccountUI(); return true; }
function modalWrap(inner){ return '<div class="overlay" onclick="if(event.target===this)closeModal()"><div class="modal">'+inner+'</div></div>'; }
function showModal(inner){ document.getElementById('modalRoot').innerHTML=modalWrap(inner); }
function proLock(){ return isPremium()?'':' <span class="prolock">'+I.lock+' '+t('pro_only')+'</span>'; }
function needPremium(){ if(!isLogged()){ openAuth('login'); return true; } if(!isPremium()){ openUpgrade(); return true; } return false; }
function toast(msg){ var d=document.createElement('div'); d.textContent=msg; d.style.cssText='position:fixed;left:50%;bottom:28px;transform:translateX(-50%);background:var(--ink);color:#fff;padding:12px 20px;border-radius:12px;z-index:300;font-size:14px;box-shadow:var(--shadow-lg)'; document.body.appendChild(d); setTimeout(function(){ d.remove(); },2600); }

var authMode='login';
/* ---- reglas de contraseña ---- */
var PW_RULES=[
  { k:'pw_len',  rx:/.{8,}/ },
  { k:'pw_upper',rx:/[A-Z]/ },
  { k:'pw_lower',rx:/[a-z]/ },
  { k:'pw_num',  rx:/[0-9]/ },
  { k:'pw_sym',  rx:/[@$!%*?&#^()\-_+=.,;:{}\[\]~]/ }
];
function pwScore(v){ var n=0; PW_RULES.forEach(function(r){ if(r.rx.test(v||'')) n++; }); return n; }
function pwValid(v){ return pwScore(v)===PW_RULES.length; }
function pwRulesHTML(){
  return '<div class="pw-bar"><span id="pwBar"></span></div><div class="pw-rules" id="pwRules">'+
    PW_RULES.map(function(r,i){
      return '<div class="pw-rule" data-r="'+i+'"><span class="dot"><svg width="9" height="9" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="3.4" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6L9 17l-5-5"/></svg></span>'+t(r.k)+'</div>';
    }).join('')+'</div>';
}
function pwCheck(){
  var v=(document.getElementById('auPass')||{}).value||'';
  var c=(document.getElementById('auPass2')||{}).value||'';
  var n=pwScore(v);
  var bar=document.getElementById('pwBar'); if(bar) bar.style.width=(n/PW_RULES.length*100)+'%';
  document.querySelectorAll('#pwRules .pw-rule').forEach(function(el,i){
    el.classList.toggle('ok', PW_RULES[i].rx.test(v));
  });
  var f2=document.getElementById('fldPass2');
  if(f2){
    var mismatch = c.length>0 && c!==v;
    f2.classList.toggle('err', mismatch);
    f2.classList.toggle('match', c.length>0 && c===v);
  }
  var btn=document.getElementById('auGo');
  if(btn){ var ok=pwValid(v) && c===v && c.length>0; btn.disabled=!ok; btn.style.opacity=ok?'1':'.5'; btn.style.cursor=ok?'pointer':'not-allowed'; }
}
function drawAuth(){ var reg=authMode==='register';
  showModal('<div class="modal-head"><h3>'+(reg?t('auth_register'):t('auth_login'))+'</h3><button class="xbtn" onclick="closeModal()">'+I.x+'</button></div>'+
    '<div class="auth-tabs"><button class="'+(reg?'':'active')+'" onclick="openAuth(\'login\')">'+t('auth_login')+'</button><button class="'+(reg?'active':'')+'" onclick="openAuth(\'register\')">'+t('auth_register')+'</button></div>'+
    (reg?'<div class="fld"><label>'+t('auth_name')+'</label><input id="auName" type="text" autocomplete="name"></div>':'')+
    '<div class="fld"><label>'+t('auth_email')+'</label><input id="auEmail" type="email" autocomplete="email"></div>'+
    '<div class="fld"><label>'+t('auth_pass')+'</label><input id="auPass" type="password" autocomplete="'+(reg?'new-password':'current-password')+'" oninput="pwCheck()"></div>'+
    (reg? pwRulesHTML() : '')+
    (reg?'<div class="fld" id="fldPass2"><label>'+t('auth_pass2')+'</label><input id="auPass2" type="password" autocomplete="new-password" oninput="pwCheck()"><span class="fld-msg">'+t('auth_nomatch')+'</span></div>':'')+
    (reg?'<label class="consent"><input type="checkbox" id="auConsent"><span>'+t('auth_consent')+'</span></label>':'')+
    '<button class="btn btn-blue block" id="auGo" onclick="doAuth()"'+(reg?' disabled style="opacity:.5;cursor:not-allowed"':'')+'>'+(reg?t('auth_send_code'):t('auth_go'))+'</button>'+
    '<p class="demo-note">'+t('auth_demo')+'</p>');
  if(reg) pwCheck();
}

/* ---- verificación por código de 6 dígitos ---- */
var PENDING=null, otpTimer=null, otpTick=null;
function randomCode(){
  try{
    var a=new Uint32Array(1); (window.crypto||window.msCrypto).getRandomValues(a);
    return String(100000 + (a[0] % 900000));
  }catch(e){ return String(100000+Math.floor(Math.random()*900000)); }
}
/* PUNTO DE ENGANCHE DEL BACKEND: aca va POST /auth/send-code (Supabase / Resend / SES).
   El codigo NUNCA debe viajar al cliente en produccion: se genera y valida server-side. */
function sendVerificationEmail(email, code){
  if(window.MA_API && typeof MA_API.sendCode==='function') return MA_API.sendCode(email);
  return Promise.resolve({ demo:true, code:code });     // demo: no hay servidor de correo
}
function doAuth(){
  var em=((document.getElementById('auEmail')||{}).value||'').trim();
  if(!em || !/^[^\s@]+@[^\s@]+\.[^\s@]{2,}$/.test(em)){ var f=document.getElementById('auEmail'); if(f) f.focus(); return; }
  if(authMode!=='register'){                                  // login (demo)
    if(!USER) USER={};
    USER.name=USER.name||em.split('@')[0]; USER.email=em; USER.plan=USER.plan||'free';
    USER.day=USER.day||dayKey(); USER.used=USER.used||0; USER.history=USER.history||[];
    saveUser(); updateAccountUI(); closeModal(); return;
  }
  var pw=(document.getElementById('auPass')||{}).value||'';
  var pw2=(document.getElementById('auPass2')||{}).value||'';
  if(!pwValid(pw) || pw!==pw2){ pwCheck(); return; }           // no se avanza sin contraseña válida y confirmada
  var nm=((document.getElementById('auName')||{}).value||'').trim()||em.split('@')[0];
  var cons=!!(document.getElementById('auConsent')&&document.getElementById('auConsent').checked);
  var code=randomCode();
  PENDING={ name:nm, email:em, discoverable:cons, code:code, exp:Date.now()+10*60*1000, tries:0, resendAt:Date.now()+30000 };
  /* la contraseña no se guarda ni viaja a localStorage: en produccion la hashea el backend */
  sendVerificationEmail(em, code).then(function(r){ drawOTP(r && r.demo ? code : null); });
}
function drawOTP(demoCode){
  if(!PENDING) return;
  var boxes='';
  for(var i=0;i<6;i++){
    boxes+='<input id="otp'+i+'" type="text" inputmode="numeric" maxlength="1" autocomplete="one-time-code" '+
      'oninput="otpInput('+i+')" onkeydown="otpKey(event,'+i+')" onpaste="otpPaste(event)">';
  }
  showModal('<div class="modal-head"><div></div><button class="xbtn" onclick="cancelOTP()">'+I.x+'</button></div>'+
    '<div class="otp-head"><div class="otp-ic"><svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="5" width="18" height="14" rx="2"/><path d="M3 7l9 6 9-6"/></svg></div>'+
      '<h3 style="font-size:21px">'+t('otp_title')+'</h3>'+
      '<p class="modal-sub" style="margin:8px 0 0">'+t('otp_sub')+'<br><span class="otp-mail">'+cvEscape(PENDING.email)+'</span></p></div>'+
    '<div class="otp-row" id="otpRow">'+boxes+'</div>'+
    '<div class="otp-err" id="otpErr"></div>'+
    '<div class="otp-meta"><span>'+t('otp_expires')+' <b id="otpClock">10:00</b></span>'+
      '<button class="link-btn" id="otpResend" onclick="resendOTP()">'+t('otp_resend')+'</button></div>'+
    '<button class="btn btn-blue block" style="margin-top:16px" onclick="verifyOTP()">'+t('otp_verify')+'</button>'+
    (demoCode? '<div class="otp-demo">'+t('otp_demo')+'<br><b>'+demoCode+'</b></div>' : '')+
  '');
  setTimeout(function(){ var f=document.getElementById('otp0'); if(f) f.focus(); },60);
  startOtpClock();
}
function startOtpClock(){
  clearInterval(otpTick);
  otpTick=setInterval(function(){
    var el=document.getElementById('otpClock'); if(!el || !PENDING){ clearInterval(otpTick); return; }
    var left=Math.max(0, PENDING.exp-Date.now());
    var m=Math.floor(left/60000), sec=Math.floor((left%60000)/1000);
    el.textContent=m+':'+(sec<10?'0':'')+sec;
    var rb=document.getElementById('otpResend');
    if(rb){ var can=Date.now()>=PENDING.resendAt; rb.disabled=!can; rb.style.opacity=can?'1':'.45'; }
    if(left<=0){ clearInterval(otpTick); otpError(t('otp_expired')); }
  },1000);
}
function otpValue(){ var v=''; for(var i=0;i<6;i++){ var el=document.getElementById('otp'+i); v+= el? (el.value||'').replace(/\D/g,'') : ''; } return v; }
function otpInput(i){
  var el=document.getElementById('otp'+i); if(!el) return;
  el.value=(el.value||'').replace(/\D/g,'').slice(0,1);
  if(el.value && i<5){ var nx=document.getElementById('otp'+(i+1)); if(nx) nx.focus(); }
  if(otpValue().length===6) verifyOTP();
}
function otpKey(e,i){
  if(e.key==='Backspace' && !e.target.value && i>0){ var pv=document.getElementById('otp'+(i-1)); if(pv){ pv.focus(); pv.value=''; } }
  if(e.key==='Enter') verifyOTP();
}
function otpPaste(e){
  var txt=((e.clipboardData||window.clipboardData).getData('text')||'').replace(/\D/g,'').slice(0,6);
  if(!txt) return; e.preventDefault();
  for(var i=0;i<6;i++){ var el=document.getElementById('otp'+i); if(el) el.value=txt[i]||''; }
  if(txt.length===6) verifyOTP();
}
function otpError(msg){
  var e=document.getElementById('otpErr'); if(e) e.textContent=msg;
  var row=document.getElementById('otpRow');
  if(row){ row.classList.add('bad'); setTimeout(function(){ row.classList.remove('bad'); },400); }
}
function verifyOTP(){
  if(!PENDING) return;
  var v=otpValue(); if(v.length<6) return;
  if(Date.now()>PENDING.exp){ otpError(t('otp_expired')); return; }
  PENDING.tries++;
  if(PENDING.tries>5){ otpError(t('otp_toomany')); PENDING=null; clearInterval(otpTick); setTimeout(closeModal,1200); return; }
  if(v!==PENDING.code){ otpError(tf('otp_wrong',{n:(6-PENDING.tries)})); return; }
  /* verificado: recien ahora existe la cuenta */
  clearInterval(otpTick);
  if(!USER) USER={};
  USER.name=PENDING.name; USER.email=PENDING.email; USER.plan=USER.plan||'free';
  USER.discoverable=PENDING.discoverable; USER.verified=true;
  USER.day=USER.day||dayKey(); USER.used=USER.used||0; USER.history=USER.history||[];
  PENDING=null; saveUser(); updateAccountUI(); closeModal(); toast(t('otp_ok'));
}
function resendOTP(){
  if(!PENDING || Date.now()<PENDING.resendAt) return;
  PENDING.code=randomCode(); PENDING.exp=Date.now()+10*60*1000; PENDING.tries=0; PENDING.resendAt=Date.now()+30000;
  sendVerificationEmail(PENDING.email, PENDING.code).then(function(r){ drawOTP(r && r.demo ? PENDING.code : null); toast(t('otp_resent')); });
}
function cancelOTP(){ PENDING=null; clearInterval(otpTick); closeModal(); }
function openAuth(mode){ authMode=mode||'login'; drawAuth(); }
function logout(){ USER=null; try{ localStorage.removeItem('ma_user'); }catch(e){} updateAccountUI(); }
function openUpgrade(){ var m=document.getElementById('acctMenu'); if(m) m.classList.remove('open');
  showModal('<div class="modal-head"><div></div><button class="xbtn" onclick="closeModal()">'+I.x+'</button></div>'+
    '<div class="up-hero"><div class="up-ic"><svg width="26" height="26" viewBox="0 0 24 24" fill="#fff" stroke="none"><path d="M12 2l2.9 6.3L22 9.2l-5 4.6 1.4 6.9L12 17.3 5.6 20.7 7 13.8 2 9.2l7.1-.9z"/></svg></div><h3 style="font-size:22px">'+t('up_title')+'</h3></div>'+
    '<p class="up-price"><b>'+t('up_price')+'</b>'+t('up_permonth')+'</p>'+
    '<ul class="up-list">'+['up_b1','up_b2','up_b3','up_b4','up_b5'].map(function(k){return '<li><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6L9 17l-5-5"/></svg><span>'+t(k)+'</span></li>';}).join('')+'</ul>'+
    '<button class="btn btn-blue block pro-btn" onclick="activatePro()">'+t('up_cta')+'</button>'+
    '<button class="btn-link" style="display:block;margin:10px auto 0" onclick="closeModal()">'+t('up_later')+'</button>'+
    '<p class="up-note">'+t('up_note')+'</p>'); }
function activatePro(){ if(!USER){ openAuth('register'); return; } USER.plan='premium'; saveUser(); updateAccountUI(); closeModal(); toast(t('up_done'));
  if(!document.getElementById('tab-analysis').classList.contains('hidden')) renderAnalysis(); }
function limitModal(){ showModal('<div class="modal-head"><h3>'+t('limit_title')+'</h3><button class="xbtn" onclick="closeModal()">'+I.x+'</button></div><p class="modal-sub">'+t('limit_body')+'</p><button class="btn btn-blue block pro-btn" onclick="openUpgrade()">'+t('go_pro')+'</button>'); }
function runLoading(cb){ var keys=['load_a','load_b','load_c','load_d','load_e'],i=0;
  showModal('<div class="load-modal"><div class="load-ring"></div><div class="load-text" id="loadT">'+t(keys[0])+'</div><div class="load-sub">MatchApply</div></div>');
  var iv=setInterval(function(){ i++; var el=document.getElementById('loadT'); if(!el){ clearInterval(iv); return; } if(i>=keys.length){ clearInterval(iv); cb(); return; } el.style.opacity='0'; setTimeout(function(){ var e2=document.getElementById('loadT'); if(e2){ e2.textContent=t(keys[i]); e2.style.opacity='1'; } },160); },720); }
var _lastCover='';
function coverFor(id){ var j=JOBS.filter(function(x){return x.id===id;})[0]; if(j) genCover(j.company, jc(j.id).title); }
function genCover(company,role){ if(needPremium()) return; runLoading(function(){ var sk=detectedSkills(document.getElementById('profile').value).slice(0,3).join(', ')||t('ad_yourarea');
  _lastCover='Estimado equipo de '+company+',\n\nMe entusiasma postularme al puesto de '+role+'. Admiro el enfoque de '+company+' en su sector y creo que mi experiencia en '+sk+' puede aportar valor desde el primer día.\n\nA lo largo de mi trayectoria trabajé en equipos ágiles entregando resultados medibles, y me motiva especialmente sumarme a un proyecto como el de '+company+'.\n\nQuedo a disposición para conversar.\n\nSaludos cordiales.';
  showModal('<div class="modal-head"><div><div class="m-kick">'+t('plan_pro')+'</div><h3>'+t('cover_title')+' · '+company+'</h3></div><button class="xbtn" onclick="closeModal()">'+I.x+'</button></div><p style="white-space:pre-wrap;font-size:14px;line-height:1.65;background:var(--panel);border-radius:12px;padding:16px">'+_lastCover.replace(/</g,'&lt;')+'</p><div class="pro-actions"><button class="act-btn" onclick="downloadPDF(_lastCover,\'Carta_MatchApply.pdf\')">'+I.check+' '+t('dl_pdf')+'</button></div><p class="demo-note">'+t('cover_note')+'</p>'); }); }
function openSim(){ if(needPremium()) return; var job=JOBS.filter(function(j){return j.id==document.getElementById('roleSel').value;})[0]||JOBS[0]; var c=jc(job.id); var sk=detectedSkills(document.getElementById('profile').value);
  var qs=c.preguntas.slice(0); qs.push(sk.length?('¿Cómo aplicaste '+sk[0]+' en un proyecto real y qué resultado tuvo?'):'Contame un logro del que estés orgulloso/a.'); qs.push('¿Por qué te interesa este puesto en particular?');
  runLoading(function(){ showModal('<div class="modal-head"><div><div class="m-kick">'+t('plan_pro')+'</div><h3>'+t('sim_title')+'</h3></div><button class="xbtn" onclick="closeModal()">'+I.x+'</button></div><p class="modal-sub">'+t('sim_note')+'</p><ol style="padding-left:20px;display:grid;gap:11px;margin:0">'+qs.slice(0,5).map(function(q){return '<li style="font-size:14.5px;line-height:1.5">'+q+'</li>';}).join('')+'</ol><button class="btn btn-blue block" style="margin-top:16px" onclick="closeModal()">'+t('close')+'</button>'); }); }
function currentRoleName(){ var v=document.getElementById('adapterSel').value; var j=(v!==''&&v!=null)?jobById(v):null; return j? jc(j.id).title : t('cv_role_generic'); }
function currentCVText(){ var sk=detectedSkills(document.getElementById('profile').value); var summary=tf('imp_sum2',{years:'',skills:(sk.slice(0,5).join(', ')||t('ad_yourarea'))});
  return currentRoleName()+'\n\n'+t('imp_h_sum')+'\n'+summary+'\n\n'+t('imp_h_skills')+'\n'+sk.join(', ')+'\n\n'+t('imp_h_exp')+'\n'+document.getElementById('profile').value; }
function cvFileName(d){ return 'CV_'+((d.name||'MatchApply').replace(/\s+/g,'_'))+'_MatchApply'; }
function cvExportData(){ cvSync(true); return cvModel(); }
function cvPDF(){
  var d=cvExportData(); var J=(window.jspdf||{}).jsPDF; if(!J){ cvDOCX(); return; }
  var doc=new J({unit:'pt',format:'a4'});
  var W=595.28, H=841.89, M=56, R=W-M, w=R-M, y=M+8;
  function need(h){ if(y+h>H-M){ doc.addPage(); y=M; } }
  doc.setFont('times','bold'); doc.setFontSize(19); need(26);
  doc.text(d.name||'', W/2, y, {align:'center'}); y+=20;
  doc.setFont('times','normal'); doc.setFontSize(9.8);
  doc.splitTextToSize(d.contactLine||t('cv_ph_contact'),w).forEach(function(l){ need(14); doc.text(l,W/2,y,{align:'center'}); y+=12; });
  y+=8;
  function sec(title){ need(36); doc.setDrawColor(50); doc.setLineWidth(.7); doc.line(M,y,R,y); y+=13;
    doc.setFont('times','bold'); doc.setFontSize(10.5); doc.text(String(title).toUpperCase(),M,y); y+=14;
    doc.setFont('times','normal'); doc.setFontSize(11.5); }
  function para(txt){ if(!txt) return; doc.splitTextToSize(txt,w).forEach(function(l){ need(15); doc.text(l,M,y); y+=13.5; }); }
  function row(left,right,italicLeft){ if(!left && !right) return; need(16);
    doc.setFont('times','italic'); doc.setFontSize(10.5); var rw=right?doc.getTextWidth(right):0;
    doc.setFont('times', italicLeft?'italic':'bold'); doc.setFontSize(11.5);
    var lines=doc.splitTextToSize(left||'', w-rw-18);
    doc.text(lines[0]||'',M,y);
    if(right){ doc.setFont('times','italic'); doc.setFontSize(10.5); doc.text(right,R,y,{align:'right'}); doc.setFontSize(11.5); }
    y+=13.5; doc.setFont('times','normal');
    for(var i=1;i<lines.length;i++){ need(15); doc.text(lines[i],M,y); y+=13.5; } }
  function bullets(list){ (list||[]).forEach(function(b){ if(!b) return;
    doc.splitTextToSize(b, w-20).forEach(function(l,i){ need(15); if(i===0) doc.text('•',M+5,y); doc.text(l,M+20,y); y+=13.5; }); }); }
  sec(t('cvh_sum')); para(d.summary); y+=4;
  sec(t('cvh_exp'));
  d.experience.forEach(function(x){ row(x.role,x.dates,false); if(x.company||x.location) row(x.company||'',x.location||'',true); bullets(x.bullets); y+=4; });
  sec(t('cvh_edu'));
  if(d.education.length) d.education.forEach(function(x){ row(x.title,x.location||'',false); if(x.detail||x.dates) row(x.detail||'',x.dates||'',true); });
  else para(t('cv_ph_edu'));
  y+=4; sec(t('cvh_skl')); para(d.skills.length? d.skills.join(' · ') : t('cv_ph_skills'));
  y+=4; sec(t('cvh_int')); para(d.interests || t('cv_ph_int'));
  doc.save(cvFileName(d)+'.pdf');
}
function cvDOCX(){
  var d=cvExportData(); var e=cvEscape;
  function sec(k,inner){ return '<p style="border-top:1px solid #333;margin:14pt 0 5pt;padding-top:3pt;font-size:10.5pt;font-weight:bold;letter-spacing:1.2pt">'+e(t(k)).toUpperCase()+'</p>'+inner; }
  function row(l,r,it){ if(!l&&!r) return '';
    return '<table width="100%" style="border-collapse:collapse;margin:0"><tr>'+
      '<td style="padding:0;'+(it?'font-style:italic':'font-weight:bold')+'">'+e(l||'')+'</td>'+
      '<td align="right" style="padding:0;font-style:italic;white-space:nowrap">'+e(r||'')+'</td></tr></table>'; }
  var expHtml=d.experience.map(function(x){ return row(x.role,x.dates,false)+((x.company||x.location)?row(x.company||'',x.location||'',true):'')+
    (x.bullets.length? '<ul style="margin:3pt 0 6pt 14pt;padding:0">'+x.bullets.filter(Boolean).map(function(b){return '<li>'+e(b)+'</li>';}).join('')+'</ul>':''); }).join('');
  var eduHtml=d.education.length? d.education.map(function(x){ return row(x.title,x.location||'',false)+((x.detail||x.dates)?row(x.detail||'',x.dates||'',true):''); }).join('')
    : '<p style="margin:0">'+e(t('cv_ph_edu'))+'</p>';
  var html='<html xmlns:o="urn:schemas-microsoft-com:office:office" xmlns:w="urn:schemas-microsoft-com:office:word"><head><meta charset="utf-8">'+
    '<style>@page{size:A4;margin:2cm} body{font-family:"Times New Roman",Garamond,serif;font-size:11.5pt;line-height:1.32;color:#111} li{margin-bottom:3pt;text-align:justify}</style></head><body>'+
    '<p style="text-align:center;font-size:19pt;font-weight:bold;letter-spacing:1pt;margin:0 0 6pt">'+e(d.name)+'</p>'+
    '<p style="text-align:center;font-size:9.5pt;margin:0;color:#333">'+e(d.contactLine||t('cv_ph_contact'))+'</p>'+
    sec('cvh_sum','<p style="margin:0;text-align:justify">'+e(d.summary)+'</p>')+
    sec('cvh_exp',expHtml)+ sec('cvh_edu',eduHtml)+
    sec('cvh_skl','<p style="margin:0">'+(d.skills.length? d.skills.map(e).join(' &middot; ') : e(t('cv_ph_skills')))+'</p>')+
    sec('cvh_int','<p style="margin:0">'+e(d.interests||t('cv_ph_int'))+'</p>')+
    '</body></html>';
  var blob=new Blob(['\ufeff',html],{type:'application/msword'});
  var url=URL.createObjectURL(blob); var a=document.createElement('a'); a.href=url; a.download=cvFileName(d)+'.doc';
  document.body.appendChild(a); a.click(); a.remove(); setTimeout(function(){ URL.revokeObjectURL(url); },1500);
}
function exportCV(fmt){ if(!isLogged()){ openAuth('login'); return; } if(fmt==='docx' && !isPremium()){ openUpgrade(); return; } if(!useCredit()){ limitModal(); return; }
  if(fmt==='pdf') cvPDF(); else cvDOCX();
  if(USER) recordHistory('CV', currentRoleName()); toast(t(fmt==='pdf'?'dl_pdf':'dl_docx')); }
function downloadPDF(text,name){ try{ var J=(window.jspdf||{}).jsPDF; if(!J){ downloadDOC(text,name.replace('.pdf','.doc')); return; } var d=new J({unit:'pt',format:'a4'}); d.setFont('helvetica'); d.setFontSize(11); var lines=d.splitTextToSize(text,500); var y=50; for(var i=0;i<lines.length;i++){ if(y>800){ d.addPage(); y=50; } d.text(lines[i],40,y); y+=15; } d.save(name); }catch(e){ downloadDOC(text,name.replace('.pdf','.doc')); } }
function downloadDOC(text,name){ var html='<html xmlns:o="urn:schemas-microsoft-com:office:office" xmlns:w="urn:schemas-microsoft-com:office:word"><head><meta charset="utf-8"></head><body style="font-family:Calibri,Arial,sans-serif;font-size:11pt">'+text.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/\n/g,'<br>')+'</body></html>'; var blob=new Blob(['﻿',html],{type:'application/msword'}); var url=URL.createObjectURL(blob); var a=document.createElement('a'); a.href=url; a.download=name; document.body.appendChild(a); a.click(); a.remove(); setTimeout(function(){ URL.revokeObjectURL(url); },1500); }
function recordHistory(company,role){ if(!USER) return; USER.history=USER.history||[]; USER.history.unshift({company:company,role:role,date:dayKey()}); if(USER.history.length>60) USER.history.length=60; saveUser(); }
function openHistory(){ var m=document.getElementById('acctMenu'); if(m) m.classList.remove('open'); var h=(USER&&USER.history)||[]; var lim=isPremium()?h.length:3; var shown=h.slice(0,lim);
  showModal('<div class="modal-head"><h3>'+t('hist_title')+'</h3><button class="xbtn" onclick="closeModal()">'+I.x+'</button></div>'+(shown.length? shown.map(function(x,i){return '<div class="hist-item"><span>'+(x.role||x.company)+' <span class="hi-d">· '+x.date+'</span></span><button class="hist-del" onclick="delHistory('+i+')">'+t('hist_del')+'</button></div>';}).join(''):'<p class="modal-sub">'+t('hist_empty')+'</p>')+((!isPremium()&&h.length>3)?'<p class="demo-note">'+t('hist_note_free')+'</p>':'')); }
function delHistory(i){ if(!USER||!USER.history) return; USER.history.splice(i,1); saveUser(); openHistory(); }
function adapterExtras(){
  var v=document.getElementById('adapterSel').value;
  var profile=document.getElementById('profile').value;
  var c=(v!=='' && v!=null)?jobById(v):null;
  var score = c ? computeScore(profile,{id:1,skills:c.skills}).score : genericScore(profile);
  var label = c ? t('ats_label') : t('ats_label_generic');
  var cr=isLogged()?'<div class="credits">'+tf('credits_txt',{n:creditsLeft(),m:dailyLimit()})+'</div>':'';
  return '<div style="margin-top:18px;font-size:14px"><b>'+label+': '+score+'%</b></div>'+cr+
    '<div class="pro-actions"><button class="act-btn" onclick="exportCV(\'pdf\')">⬇ '+t('dl_pdf')+'</button><button class="act-btn" onclick="exportCV(\'docx\')">⬇ '+t('dl_docx')+proLock()+'</button></div>'; }
function roleExtras(){ return '<div class="pro-actions"><button class="act-btn" onclick="openSim()">'+t('sim_btn')+proLock()+'</button></div>'; }
function updateAccountUI(){ var el=document.getElementById('acctArea'); if(!el) return;
  if(!isLogged()){ el.innerHTML='<button class="acct-btn" onclick="openAuth(\'login\')"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>'+t('signin')+'</button>'; return; }
  var pro=isPremium(); var ini=(USER.name||USER.email||'U').charAt(0).toUpperCase();
  el.innerHTML='<div style="position:relative"><button class="acct-btn" onclick="toggleAcct(event)"><span class="acct-av">'+ini+'</span><span class="plan-badge '+(pro?'pro':'free')+'">'+(pro?'PRO':'FREE')+'</span></button>'+
    '<div class="acct-menu" id="acctMenu"><div class="am-h"><b>'+(USER.name||'')+'</b><span>'+(USER.email||'')+' · '+(pro?t('plan_pro'):t('plan_free'))+'</span></div>'+
    (pro?'':'<button class="am-i pro-btn" style="justify-content:center;border-radius:8px;margin-bottom:4px" onclick="openUpgrade()">'+t('go_pro')+'</button>')+
    '<button class="am-i" onclick="openHistory()"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><path d="M3 3v5h5"/><path d="M3 8a9 9 0 1 0 3-5.7"/><path d="M12 7v5l3 3"/></svg>'+t('history')+'</button>'+
    '<button class="am-i" onclick="logout()"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><path d="M16 17l5-5-5-5M21 12H9"/></svg>'+t('logout')+'</button></div></div>'; }
function toggleAcct(e){ if(e) e.stopPropagation(); var m=document.getElementById('acctMenu'); if(m) m.classList.toggle('open'); }
document.addEventListener('click', function(e){ var a=document.getElementById('acctArea'); if(a && !a.contains(e.target)){ var m=document.getElementById('acctMenu'); if(m) m.classList.remove('open'); } });

document.getElementById('navMark').innerHTML=LOGO;
document.getElementById('heroLogo').innerHTML=LOGO;
(function(){ var l=document.createElement('link'); l.rel='icon'; l.href='data:image/svg+xml,'+encodeURIComponent(LOGO); document.head.appendChild(l); })();
document.addEventListener('keydown', function(e){ if(e.key==='Escape') closeModal(); });
document.getElementById('profile').addEventListener('input', function(){ renderChips(); cvInvalidate();
  if(!document.getElementById('tab-analysis').classList.contains('hidden')) renderAnalysis(); });
document.getElementById('total').textContent=JOBS.length;
/* idioma recordado + estado inicial */
try{ var _sl=localStorage.getItem('ma_lang'); if(_sl && I18N[_sl]) lang=_sl; }catch(e){}
markLang(); updateLangBtn(); loadUser(); loadChat(); cvLoadModel();
fillJobSelects(); renderChips(); render(); applyI18n(); updateAccountUI();
renderBotMsgs(); renderBotSugg();
/* el usuario vuelve exactamente a donde estaba antes del F5 */
try{ if('scrollRestoration' in history) history.scrollRestoration='manual'; }catch(e){}
restoreRoute(true);
setTimeout(moveSegIndicator,80);
window.addEventListener('hashchange', function(){ restoreRoute(true); });   // atras/adelante del navegador
/* reveal progresivo de las secciones de la landing */
function initReveal(){
  var groups=[
    ['#page-inicio .section-title, #page-inicio .section-intro', ''],
    ['#page-inicio .feature', 'rv-scale'],
    ['#page-nosotros .about-hero .eyebrow, #page-nosotros .about-hero h1', ''],
    ['#page-nosotros .about-body p, #page-nosotros .about-quote', 'rv-left'],
    ['#page-nosotros .value', 'rv-scale'],
    ['#page-herramientas .tools-hero h1, #page-herramientas .tools-hero p', '']
  ];
  var all=[];
  groups.forEach(function(g){
    var els=[].slice.call(document.querySelectorAll(g[0]));
    els.forEach(function(el,i){
      el.classList.add('reveal'); if(g[1]) el.classList.add(g[1]);
      el.style.transitionDelay=(i*70)+'ms';               // entrada escalonada
      all.push(el);
    });
  });
  if(!('IntersectionObserver' in window)){ all.forEach(function(el){ el.classList.add('in'); }); return; }
  var io=new IntersectionObserver(function(entries){
    entries.forEach(function(e){ if(e.isIntersecting){ e.target.classList.add('in'); io.unobserve(e.target); } });
  },{ threshold:.14, rootMargin:'0px 0px -8% 0px' });
  all.forEach(function(el){ io.observe(el); });
}
initReveal();

/* navbar: sombra al scrollear + se esconde al bajar y vuelve al subir */
(function(){
  var n=document.querySelector('nav.top'); if(!n) return;
  var last=window.scrollY||0, ticking=false, TH=6, MIN=110;
  function menusOpen(){
    return document.querySelector('.lang-menu.open, .acct-menu.open, .overlay') !== null ||
           document.activeElement===document.getElementById('langBtn');
  }
  var spyRoute=null;
  function scrollSpy(y){
    /* solo aplica en la landing (Inicio + Quienes somos comparten scroll) */
    if(currentPage==='herramientas') return;
    var ab=document.getElementById('page-nosotros'); if(!ab) return;
    var top=ab.getBoundingClientRect().top+y;
    var here=(y+96>=top) ? 'nosotros' : 'inicio';
    if(here===spyRoute) return;
    spyRoute=here;
    currentPage=here;
    setNavActive(here);
    saveRoute();                                    // la URL acompaña al scroll
  }
  function update(){
    var y=window.scrollY||0, dy=y-last;
    n.classList.toggle('scrolled', y>8);
    scrollSpy(y);
    if(menusOpen() || y<MIN){ n.classList.remove('nav-hidden'); }
    else if(dy>TH){ n.classList.add('nav-hidden'); }        // bajando -> se va hacia arriba
    else if(dy<-TH){ n.classList.remove('nav-hidden'); }    // subiendo -> vuelve
    last=y<0?0:y; ticking=false;
  }
  window.addEventListener('scroll',function(){ if(!ticking){ ticking=true; requestAnimationFrame(update); } },{passive:true});
  update();
})();
</script>
</body>
</html>
