function jcGenerated(j){
  var L=GEN_TXT[lang]||GEN_TXT.es;
  var cat=CATALOG[j.cat];
  var role=(cat.t[lang]||cat.t.es);
  var sk=j.skills.map(cap);
  var fill=function(x){ return x.replace('{s}',sk.slice(0,3).join(', ')).replace('{s1}',sk[0]||role)
                          .replace('{m}',sk.slice(-2).join(' y ')).replace('{role}',role); };
  return { title:role, location:j.location[lang]||j.location.es,
    valoran:L.v.map(fill), mejorar:L.m.map(fill), prep:L.p.map(fill), preguntas:L.q.map(fill) };
}
var JOBS_CURATED=JOBS.slice();
function buildCatalogJobs(){
  CATALOG.forEach(function(c,i){
    var id=JOBS_CURATED.length+1+i;
    var loc={}; ['es','en','fr','pt'].forEach(function(l){ loc[l]=(GEN_LOC[l]||GEN_LOC.es)[i%4]; });
    JOBS.push({
      id:id, cat:i, company:GEN_COMPANIES[i%GEN_COMPANIES.length],
      salary:GEN_SAL[i%GEN_SAL.length], isPartner:(i%7===0), skills:c.skills.slice(),
      mod:(i%4===1?'hibrido':(i%4===3?'presencial':'remoto')), jor:(i%5===4?'part':'full'),
      location:loc
    });
  });
}
function jobById(id){ for(var i=0;i<JOBS.length;i++){ if(JOBS[i].id==id) return JOBS[i]; } return null; }

