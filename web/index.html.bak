let lang = 'es';
try { lang = localStorage.getItem('ma_lang') || 'es'; } catch(e){}
function t(k){ return (I18N[lang] && I18N[lang][k]) || I18N.es[k] || k; }
function tf(k, o){ let s = t(k); for (var p in o){ s = s.split('{'+p+'}').join(o[p]); } return s; }

