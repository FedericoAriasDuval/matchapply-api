  cv_add_bullet:"réalisation", cv_add_exp:"expérience", cv_add_edu:"formation", cv_del:"Supprimer",
  ai_disclaimer:"L'IA peut se tromper ; vérifiez toujours les données. Nous ne recommandons jamais de mentir sur votre CV.",
  bot_disclaimer:"L'IA peut se tromper ; vérifiez toujours les données. Nous ne recommandons jamais de mentir sur votre CV.",
  tools_all:"Voir tous les outils",
  lead_auto:"On trouve les offres compatibles et on prépare chaque candidature avec votre CV.",
  ap_nofilter:"Si vous ne sélectionnez aucune option, nous n'appliquons aucune restriction : nous cherchons largement toutes les offres disponibles compatibles avec votre profil.",
  lead_matches:"On vous montre où vous avez de vraies chances, et pourquoi.",
  lead_adapter:"On ajuste votre CV aux mots-clés du poste choisi.",
  lead_analysis:"Ce qui marche, ce qui manque, et une version soignée en retour.",
  lead_role:"Ce qu'ils vont évaluer et les questions qui vous attendent.",
  reader_pick:"Qui va lire votre CV ?", prof_sync:"Adaptation de votre profil…", cv_undo:"Annuler", cv_ph_loc:"Ville, Pays", cv_restored:"CV restauré au brouillon d'origine.",
  reader_hh_d:"Parcourt en quelques secondes : séniorité et adéquation avec son client.",
  reader_hr_d:"Vérifie les exigences de l'offre et les trous inexpliqués.",
  reader_bot_d:"Lit du texte brut : colonnes, tableaux et images passent mal.",
  cv_translated:"Traduit automatiquement",
  cv_edit_pro:"Éditer à la main · PRO", cv_edit_on:"Édition activée", cv_edit_off:"Activer l'édition",
  cv_edit_hint_free:"L'édition manuelle est une fonction Pro. Avec votre formule actuelle, vous pouvez télécharger le PDF du CV généré.",
  cv_edited:"Modifié par vous", cv_edit_hint:"Cliquez sur une ligne pour la modifier. L'export reprend exactement ce que vous voyez.", cv_restore:"Revenir au brouillon automatique",
  bot_thanks:"Avec plaisir ! Autre chose sur MatchApply ?", chat_clear:"Effacer la conversation",
  hero_eyebrow:"Obsédés par votre recherche", hero_title:"Trouvez le bon emploi et arrivez préparé",
  hero_sub:"MatchApply trouve les offres qui vous correspondent vraiment, adapte votre CV à chaque recherche et, en un clic, prépare et envoie toutes vos candidatures.",
  hero_start:"Commencer", hero_more:"En savoir plus ›",
  feat_title:"Comment fonctionne MatchApply ?", feat_intro:"Des outils pour cesser d'envoyer le même CV partout et postuler avec discernement.",
  f1_h:"Match intelligent", f1_p:"Un score de 0 à 100 qui compare votre profil à chaque offre, avec des raisons concrètes.",
  f2_h:"CV sur mesure", f2_p:"Nous adaptons votre CV aux mots-clés de chaque recherche, sans toucher à votre version de base.",
  f3_h:"Prêt pour l'entretien", f3_p:"Ce qui compte pour chaque poste, quoi renforcer et les questions les plus probables.",
  cta_h:"Commencez aujourd'hui.", cta_p:"Renseignez votre profil une fois et laissez les outils faire le gros du travail.", cta_btn:"Essayer MatchApply",
  ab_eyebrow:"Qui sommes-nous ?", ab_title:"Nous croyons que chercher un emploi peut être différent.",
  ab_p1:"MatchApply est né d'une conviction simple : le temps d'un candidat compte, et aujourd'hui il est gaspillé. Chaque poste reçoit des centaines de candidatures, et la plupart envoient le même CV partout, sans savoir où ils ont vraiment leurs chances.",
  ab_p2:"Nous avons voulu changer cela avec des outils concrets : un score qui compare votre profil à chaque offre, un assistant qui adapte votre CV à ce que chaque recherche demande, et un guide qui vous prépare à l'entretien. Le tout à partir d'un profil rempli une seule fois.",
  ab_quote_txt:"« Postuler devrait coûter du temps en entretiens, pas en formulaires. »", ab_quote_by:"Notre principe",
  ab_p3:"Une seule obsession : que postuler se vive autrement. Chaque détail — le score qui vous dit où vous avez vos chances, le CV qui s'adapte tout seul, la préparation avant l'entretien — existe pour que vous alliez plus loin avec moins d'usure. L'expérience doit être à la hauteur du poste que vous visez.",
  val1_h:"Votre temps d'abord", val1_p:"Nous vous aidons à concentrer vos efforts là où vous avez de réelles opportunités.",
  val2_h:"Du discernement, pas du volume", val2_p:"Il ne s'agit pas de tout postuler, mais de bien postuler.",
  ab_cta_p:"Tout cela vous attend déjà de l'autre côté.",
  val3_h:"Une expérience premium", val3_p:"Des outils de niveau professionnel pour que chacune de vos candidatures joue en première division.", ab_btn:"Essayer les outils",
  tools_h:"Vos outils", tools_p:"Renseignez votre profil une seule fois et servez-vous-en partout. C'est vous qui choisissez par où commencer.",
  tab_auto:"Candidature auto", tab_matches:"Offres", tab_adapter:"CV sur mesure", tab_analysis:"Diagnostic", tab_role:"Entretien",
  prof_label:"Votre profil / CV de base", prof_upload:"Importer le CV (PDF/DOCX)",
  prof_ph:"Collez votre profil ou CV en texte...",
  cv_reading:"Lecture de votre CV…", cv_done:"CV chargé et lu. Vérifiez le texte et utilisez-le dans les outils.", cv_err:"Impossible de lire le fichier. Essayez un PDF ou DOCX avec du texte sélectionnable.",
  chips_label:"Détectés",
  ap_h:"Candidature automatique", ap_p:"Dites-nous ce que vous cherchez et on s'occupe du reste. On repère les offres qui vous correspondent et on prépare chaque candidature avec votre CV. Le dernier mot vous revient toujours : rien ne part sans votre accord.",
  ap_mod:"Mode de travail", ap_remote:"À distance", ap_hybrid:"Hybride", ap_onsite:"Sur site",
  ap_jor:"Temps de travail", ap_full:"Temps plein", ap_part:"Temps partiel", ap_loc:"Lieu ou fuseau horaire",
  ap_btn:"Chercher et postuler · 1 clic", ap_note:"Utilise votre CV ci-dessus. Vous pouvez vérifier et confirmer chaque envoi.",
  ap_noprofile:"Ajoutez votre profil ou CV ci-dessus pour démarrer.", ap_nojobs_t:"Aucune offre trouvée", ap_nojobs_p:"Aucune offre pour ces préférences. Élargissez le mode ou le temps de travail.",
  ap_scan_t:"Recherche d'offres en temps réel…", ap_scan_p:"Parcours des principales sources d'emploi et mesure de compatibilité avec votre profil.",
  ap_revised:"vérifié", ap_searching:"recherche…", ap_queue:"en file",
  ap_apply_t:"Candidature à {n} offres compatibles", ap_apply_p:"Remplissage et envoi d'un formulaire par offre avec vos données.", ap_sent:"envoyée",
  ap_done:"{n} candidatures envoyées.", ap_done_note:"Nous avons postulé à toutes les offres compatibles avec vos préférences. Dans la vraie version, vous pourrez vérifier chacune avant l'envoi final si vous préférez.", ap_kick:"Candidature automatique", ap_ready_btn:"Terminé",
  m_h:"Offres classées par compatibilité", m_p:"Nous comparons votre profil à chaque offre et vous disons franchement où vous avez de vraies chances, et pourquoi. Postulez à celle qui vous parle le plus, ou cochez-en plusieurs et envoyez-les ensemble.",
  m_analyze:"Analyser mes opportunités", m_analyzing:"Analyse…", m_again:"Analyser à nouveau", m_stat_analyzed:"analysées", m_stat_excellent:"excellentes",
  batch_text:"Vous avez sélectionné {n} offre{s} à postuler ensemble.", batch_clear:"Effacer", batch_btn:"Postuler aux {n}",
  best:"Votre meilleur match", partner:"Entreprise partenaire", noscore:"Non analysé", apply_btn:"Postuler en 1 clic", applied:"Candidature envoyée", sumsel:"Ajouter à la sélection",
  tag_exc:"Excellent", tag_par:"Partiel", tag_low:"Faible",
  r_match:"Vous correspondez à {n} des {m} exigences : {list}.", r_nomatch:"Votre profil ne mentionne pas les exigences centrales de cette recherche.", r_reinforce:"À renforcer : {list}.",
  r_high:"Compatibilité élevée : à prioriser.", r_mid:"Compatibilité partielle : postulez si le reste du poste vous intéresse.", r_low:"Compatibilité faible : sans doute pas rentable en temps.",
  ad_h:"Votre CV, adapté à chaque recherche", ad_p:"Choisissez le poste qui vous intéresse : on vous montre ce qui joue déjà en votre faveur, ce qu'il vaut la peine d'ajouter et comment sonne votre résumé pour cette recherche. Votre CV de base reste tel que vous l'avez écrit.",
  ad_for:"Adapter pour :", ad_has:"Déjà dans votre CV", ad_add:"À ajouter", ad_all:"Vous les incluez déjà toutes",
  ad_tape:"Résumé sur mesure · ", ad_sumtitle:"Résumé professionnel", ad_basenote:"Votre CV de base n'est pas modifié : c'est une couche séparée générée pour chaque recherche.",
  ad_sum1:"Professionnel orienté {role} avec de l'expérience en {skills}.", ad_sum2:" Profil ajusté pour cette recherche, en ajoutant {add} comme mots-clés prioritaires de l'offre.", ad_sum3:" Axé sur un impact mesurable dès le premier jour.", ad_yourarea:"votre domaine",
  an_h:"Diagnostic de votre CV", an_p:"Un même CV ne se lit pas pareil selon qu'il passe entre les mains d'un chasseur de têtes pressé, d'un service RH ou d'un filtre automatique. Dites-nous qui va le lire : on ajuste les conseils et on vous rend une version soignée, prête à envoyer.",
  reader_hh:"Chasseur de têtes", reader_hr:"RH interne", reader_bot:"Système ATS",
  str_title:"Points forts", wea_title:"À améliorer", fmt_title:"Format recommandé s'il est évalué par : ",
  str1a:"Stack technique varié et facile à repérer : {list}.", str1b:"Compétences concrètes détectées : {list}.", str1c:"Vous pourriez nommer vos compétences plus explicitement.",
  str2:"Le profil indique des années d'expérience — cela donne un contexte de séniorité.", str3:"Rédaction directe, sans remplissage.",
  wea1:"Il manque des résultats chiffrés (ex. : « réduit X de 30 % », « dirigé une équipe de 4 »).", wea2:"Le résumé est générique : il ne vise pas un poste précis.", wea3:"Peu de mots-clés de l'offre à laquelle vous postulez.",
  imp_tape:"Version améliorée", imp_title:"Votre CV, mis en forme professionnelle", imp_note:"Suggestions pour un rendu plus professionnel :",
  imp_sum:"Professionnel avec une expérience avérée en {skills}. Antécédents dans la création de solutions de bout en bout et le travail en équipes agiles. Orienté résultats mesurables et amélioration continue, avec une communication claire et le sens de l'impact business.",
  imp_s1:"Remplacez les tâches par des résultats chiffrés (ex. : « amélioré X de 25 % »).", imp_s2:"Ajoutez en haut un résumé de 2 lignes ciblé sur le poste visé.", imp_s3:"Incluez les mots-clés exacts de l'offre visée.",
  role_h:"Préparation à l'entretien", role_p:"Dites-nous le poste que vous visez et on vous dit ce qu'ils vont regarder, ce qu'il vaut mieux renforcer et les questions que vous risquez de croiser. Moins de stress, de meilleures réponses.",
  role_puesto:"Poste :", role_val:"Ce qui compte pour {role}", role_imp:"Compétences à renforcer", role_prep:"Comment préparer l'entretien", role_q:"Questions probables",
  apply_kick:"Candidature", apply_sub:"Simulation : voici comment le formulaire serait rempli sur le site de l'entreprise.", apply_done:"Formulaire complété avec vos données.", apply_note:"Vérifiez et confirmez sur le site de l'entreprise pour l'envoyer. MatchApply n'envoie jamais la candidature à votre place.", close:"Fermer", filling:"Remplissage avec vos données…",
  batch_kick:"Candidature groupée", batch_title:"Candidature à {n} offres", batch_sub:"Simulation : un formulaire est rempli par offre.", batch_ready:"prête", batch_done:"{n} candidatures préparées.", batch_note:"Chacune est prête avec vos données. Vérifiez et confirmez sur le site de chaque entreprise — MatchApply ne les envoie jamais à votre place.", entendido:"Compris",
  f_name:"Nom complet", f_email:"E-mail", f_phone:"Téléphone", f_link:"LinkedIn", f_cv:"CV", f_letter:"Lettre de motivation", f_cv_v:"CV_Camila_Torres.pdf", f_letter_v:"Générée depuis votre profil",
  foot:"MatchApply · Version démo — le score et les textes sont calculés localement dans votre navigateur et les données sont des exemples. En production, le calcul tourne sur un serveur avec un modèle de langage et les offres proviennent d'une source réelle.",
  bot_name:"Assistant MatchApply", bot_status:"Je réponds à vos questions", bot_ph:"Écrivez votre question…",
  bot_hi:"Bonjour ! Je suis l'assistant MatchApply. Comment puis-je aider ? Vous pouvez me demander comment ça marche, ce qu'inclut Premium, comment le match est calculé et plus encore.",
  bot_fallback:"Bonne question. Je peux vous parler de : ce qu'est MatchApply, les formules et Premium, comment fonctionne le match, le CV sur mesure, le pilote automatique, la préparation d'entretien ou la confidentialité. Lequel vous intéresse ?",
  bot_s1:"Qu'est-ce que MatchApply ?", bot_s2:"Que comprend Premium ?", bot_s3:"Comment fonctionne le match ?",
