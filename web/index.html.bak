/* ============ skills / scoring ============ */
const KNOWN_SKILLS = [
  /* lenguajes */ "javascript","typescript","python","java","kotlin","swift","c++","c#","go","golang","rust","php","ruby","scala","r","matlab","sql","html","css","sass",
  /* front */ "react","react native","next.js","vue","angular","svelte","tailwind","bootstrap","redux","jquery","frontend","ux","ui","responsive",
  /* back */ "node","express","django","flask","fastapi","spring","laravel","rails",".net","graphql","api rest","rest","microservicios","backend","full stack",
  /* datos */ "postgresql","mysql","sql server","oracle","mongodb","redis","firebase","supabase","bigquery","snowflake","etl","pandas","numpy","spark","hadoop","power bi","tableau","looker","excel","google sheets","machine learning","data science",
  /* cloud / devops */ "aws","gcp","azure","docker","kubernetes","terraform","jenkins","github actions","ci/cd","linux","nginx","git","github","gitlab",
  /* producto / diseño / gestión */ "figma","sketch","adobe xd","photoshop","illustrator","canva","jira","asana","trello","notion","scrum","kanban","agile","ágil","product management","seo","sem","google analytics","hubspot","salesforce","sap","crm",
  /* idiomas */ "inglés","english","español","portugués","francés","alemán","italiano"
];
function stripAccents(t){ return t.normalize("NFD").replace(/[̀-ͯ]/g,""); }
function normalize(x){ return " " + stripAccents(x.toLowerCase()).replace(/[^a-z0-9.+#/ ]/g," ").replace(/\s+/g," ") + " "; }
function skillPresent(p, sk){ const s = stripAccents(sk.toLowerCase()).trim(); if(!s.includes(" ")) return p.includes(" "+s+" ")||p.includes(" "+s+"s ")||p.includes(" "+s+"."); if(p.includes(s)) return true; const w = s.split(" ").filter(z=>z.length>=3); return w.length>0 && w.every(z=>p.includes(z)); }
function cap(s){ return s.charAt(0).toUpperCase()+s.slice(1); }
function detectedSkills(profile){ const p=normalize(profile); return KNOWN_SKILLS.filter(sk=>skillPresent(p,sk)).map(cap); }
function renderChips(){ const sk=detectedSkills(document.getElementById('profile').value); const el=document.getElementById('chips');
  el.innerHTML = sk.length ? '<span class="chips-label">'+t('chips_label')+'</span>'+sk.slice(0,12).map(function(s){return '<span class="chip">'+s+'</span>';}).join('') : ''; }
function computeScore(profile, job){
  const p=normalize(profile); const matched=[],missing=[];
  job.skills.forEach(sk=>(skillPresent(p,sk)?matched:missing).push(sk));
  const ratio=matched.length/job.skills.length;
  let score=Math.round(24+ratio*68); score+=((job.id*7)%5)-2; score=Math.max(6,Math.min(97,score));
  const reasons=[];
  if(matched.length) reasons.push(tf('r_match',{n:matched.length,m:job.skills.length,list:matched.slice(0,3).map(cap).join(", ")}));
  else reasons.push(t('r_nomatch'));
  if(missing.length && matched.length) reasons.push(tf('r_reinforce',{list:missing.slice(0,3).map(cap).join(", ")}));
  if(score>=80) reasons.push(t('r_high')); else if(score>=50) reasons.push(t('r_mid')); else reasons.push(t('r_low'));
  return { score, reasons:reasons.slice(0,3), matched, missing };
}
function scoreStyle(score){ if(score>=80) return {fg:'#1d8a4e',bg:'#e7f4ec',label:t('tag_exc')}; if(score>=50) return {fg:'#9a6a00',bg:'#f6efdd',label:t('tag_par')}; return {fg:'#c0362c',bg:'#f7e6e4',label:t('tag_low')}; }

