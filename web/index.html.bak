/* el formulario se completa SOLO con datos que figuran en el CV cargado; nada de la cuenta ni de ejemplos */
function applyFields(){
  var txt=(document.getElementById('profile')||{}).value||'';
  var name=cvGuessName(txt);
  var bits=cvContactBits(txt);
  var pick=function(rx){ for(var i=0;i<bits.length;i++){ if(rx.test(bits[i])) return bits[i]; } return ''; };
  var dash='—';
  return [
    { label:t('f_name'),  value:name || dash },
    { label:t('f_email'), value:pick(/@/) || dash },
    { label:t('f_phone'), value:pick(/^\+?[\d ().-]{8,}$/) || dash },
    { label:t('f_link'),  value:pick(/linkedin\.com/i) || dash },
    { label:t('f_cv'),    value:(txt.trim()? (name? 'CV_'+name.replace(/\s+/g,'_')+'.pdf' : t('f_cv_v')) : dash) },
    { label:t('f_letter'),value:t('f_letter_v') }
  ];
}

