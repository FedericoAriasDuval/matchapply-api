  batch_kick:"Batch application", batch_title:"Applying to {n} jobs", batch_sub:"Simulation: one form is filled per job.", batch_ready:"ready", batch_done:"{n} applications prepared.", batch_note:"Each one is ready with your data. Review and confirm on each company's site — MatchApply never sends them for you.", entendido:"Got it",
  f_name:"Full name", f_email:"Email", f_phone:"Phone", f_link:"LinkedIn", f_cv:"CV", f_letter:"Cover letter", f_cv_v:"CV_Camila_Torres.pdf", f_letter_v:"Generated from your profile",
  foot:"MatchApply · Demo version — the score and texts are computed locally in your browser and the data is sample data. In production the computation runs on a server with a language model and the jobs come from a real source.",
  bot_name:"MatchApply Assistant", bot_status:"I answer your questions", bot_ph:"Type your question…",
