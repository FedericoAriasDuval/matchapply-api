  loader:'<svg class="spin" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round"><path d="M12 3a9 9 0 1 0 9 9"/></svg>',
  x:'<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6L6 18M6 6l12 12"/></svg>',
  lock:'<svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><rect x="4" y="11" width="16" height="10" rx="2"/><path d="M8 11V7a4 4 0 0 1 8 0v4"/></svg>'
};
const LOGO = '<svg viewBox="0 0 100 100" xmlns="http://www.w3.org/2000/svg"><rect x="2" y="2" width="96" height="96" rx="22" fill="#15294d"/><path d="M24 70 V33 L38 55 L52 33 V70" fill="none" stroke="#ffffff" stroke-width="9" stroke-linejoin="round" stroke-linecap="round"/><path d="M55 70 L67 33 L79 70 M60 57 H74" fill="none" stroke="#2f6bff" stroke-width="9" stroke-linejoin="round" stroke-linecap="round"/><path d="M24 80 Q50 92 76 74" fill="none" stroke="#ffffff" stroke-width="4.5" stroke-linecap="round"/><path d="M76 74 l2 8 l-8 -1 z" fill="#ffffff"/><circle cx="50" cy="49" r="6.5" fill="#4d8bff" stroke="#15294d" stroke-width="2"/><path d="M39 66 q11 -13 22 0 z" fill="#4d8bff" stroke="#15294d" stroke-width="2"/></svg>';

function ring(score, st){ const r=36,circ=2*Math.PI*r,off=circ*(1-score/100);
  return '<div class="ring-wrap"><svg width="82" height="82" viewBox="0 0 82 82"><circle class="ring-bg" cx="41" cy="41" r="'+r+'" fill="none" stroke-width="6"/><circle class="ring-fg" cx="41" cy="41" r="'+r+'" fill="none" stroke="'+st.fg+'" stroke-width="6" stroke-dasharray="'+circ+'" stroke-dashoffset="'+circ+'" data-off="'+off+'"/></svg><div class="ring-num"><b style="color:'+st.fg+'">'+score+'</b><small>match</small></div></div>'; }

/* ============ navigation + routing (#herramientas/diagnostico) ============ */
var TAB_SLUG={ auto:'postulacion-automatica', matches:'ofertas', adapter:'cv-a-medida', analysis:'diagnostico', role:'entrevista' };
var SLUG_TAB={}; for(var _k in TAB_SLUG){ SLUG_TAB[TAB_SLUG[_k]]=_k; }
SLUG_TAB['piloto-automatico']='auto';   // alias: rutas viejas guardadas siguen funcionando
var currentPage='inicio', routing=false;
function saveRoute(){
  if(routing) return;
  var h='#'+currentPage+(currentPage==='herramientas' ? '/'+(TAB_SLUG[currentTab]||'postulacion-automatica') : '');
  try{ if(location.hash!==h && history.replaceState) history.replaceState(null,'',h); else if(!history.replaceState) location.hash=h; }catch(e){}
  try{ localStorage.setItem('ma_route',h.slice(1)); }catch(e){}
}
function readRoute(){
  var h=(location.hash||'').replace(/^#\/?/,'');
  if(!h){ try{ h=localStorage.getItem('ma_route')||''; }catch(e){ h=''; } }
  var parts=String(h).split('/');
  var page=parts[0]||'inicio';
  if(['inicio','nosotros','herramientas'].indexOf(page)<0) page='inicio';
  return { page:page, tab:SLUG_TAB[parts[1]]||null };
}
/* CTA de "Quienes somos": abre Herramientas y hace scroll suave hasta el modulo */
function goTools(){
  showPage('herramientas');
  setTimeout(function(){
    var el=document.querySelector('#page-herramientas .tools-hero');
    if(!el){ window.scrollTo({top:0,behavior:'smooth'}); return; }
    var top=el.getBoundingClientRect().top+(window.scrollY||0)-52;
    window.scrollTo({ top:Math.max(0,top), behavior:'smooth' });
  },60);
  pulseProfile();
}
function setNavActive(name){
  document.querySelectorAll('.nav-links button').forEach(function(b){
    var on=b.dataset.page===name;
    b.classList.toggle('active',on);
    b.setAttribute('aria-current', on?'page':'false');
  });
}
function showPage(name){
  currentPage=name;
  var home=(name!=='herramientas');
  document.getElementById('page-inicio').classList.toggle('active',home);
  document.getElementById('page-nosotros').classList.toggle('active',home);
  document.getElementById('page-herramientas').classList.toggle('active',name==='herramientas');
  setNavActive(name);
  if(name==='nosotros'){
    setTimeout(function(){
      var e=document.getElementById('page-nosotros'); if(!e) return;
      var top=e.getBoundingClientRect().top+(window.scrollY||0)-56;   // deja respirar la navbar
      window.scrollTo({top:Math.max(0,top),behavior:'smooth'});
    },70);
  } else { window.scrollTo({top:0,behavior:'smooth'}); }
  if(typeof initReveal==='function') setTimeout(initReveal,40);       // reobserva lo que aparece de nuevo
  if(name==='herramientas') setTimeout(moveSegIndicator,60);
  saveRoute();
}
var TABS=['auto','matches','adapter','analysis','role'], currentTab='auto', tabAnim=null, profTimer=null;
function pulseProfile(){
  var box=document.querySelector('.prof-box'); if(!box) return;
  box.classList.remove('syncing'); void box.offsetWidth;   // reinicia la animacion
  box.classList.add('syncing');
  clearTimeout(profTimer);
  profTimer=setTimeout(function(){ box.classList.remove('syncing'); }, 640);
}
function renderTab(name){ if(name==='adapter') renderAdapter(); else if(name==='analysis') renderAnalysis(); else if(name==='role') renderRole(); }
/* ---- modo enfoque: la barra de subsecciones se retira al abrir una herramienta ---- */
function updateFocusLabel(){
  var el=document.getElementById('toolsCurrent'); if(!el) return;
  el.textContent=t('tab_'+currentTab);
}
function enterFocus(){
  var pg=document.getElementById('page-herramientas'); if(!pg) return;
  pg.classList.add('focus'); updateFocusLabel();
}
function exitFocusSilent(){ var pg=document.getElementById('page-herramientas'); if(pg) pg.classList.remove('focus'); }
function exitFocus(){
  var pg=document.getElementById('page-herramientas'); if(!pg) return;
  pg.classList.remove('focus');
  setTimeout(function(){ moveSegIndicator(); }, 60);      // el subrayado se recalcula ya visible
  var seg=document.querySelector('#page-herramientas .seg-wrap');
  if(seg){ var top=seg.getBoundingClientRect().top+(window.scrollY||0)-70;
    window.scrollTo({ top:Math.max(0,top), behavior:'smooth' }); }
}
/* subrayado que se desliza bajo la pestaña activa */
function moveSegIndicator(){
  var seg=document.getElementById('seg'); if(!seg) return;
  var act=seg.querySelector('button.active'); if(!act) return;
  var x=act.offsetLeft-seg.scrollLeft, w=act.offsetWidth;
  seg.style.setProperty('--ind-x', x+'px');
  seg.style.setProperty('--ind-w', w+'px');
  seg.style.setProperty('--ind-o', '1');
}
window.addEventListener('resize', function(){ moveSegIndicator(); });
(function(){ var seg=document.getElementById('seg'); if(seg) seg.addEventListener('scroll', moveSegIndicator, {passive:true}); })();
function switchTab(name){
  if(name===currentTab || TABS.indexOf(name)<0) return;
  var fwd = TABS.indexOf(name) > TABS.indexOf(currentTab);
  var out = document.getElementById('tab-'+currentTab);
  var inn = document.getElementById('tab-'+name);
  document.querySelectorAll('#seg button').forEach(function(b){
    var on=b.dataset.tab===name; b.classList.toggle('active',on); b.setAttribute('aria-selected',on?'true':'false'); });
  moveSegIndicator();                  // el subrayado se desliza hasta la nueva pestaña
  enterFocus();                        // y la barra se retira: modo enfoque en la herramienta
  pulseProfile();                      // el bloque de perfil se refresca junto con la herramienta
  clearTimeout(tabAnim);
  out.classList.remove('from-left'); out.classList.add('tab-out'); out.classList.toggle('to-right',!fwd);
  currentTab=name;
  tabAnim=setTimeout(function(){
    TABS.forEach(function(x){ var el=document.getElementById('tab-'+x);
      el.classList.add('hidden'); el.classList.remove('tab-out','to-right','from-left'); });
    renderTab(name);
    inn.classList.remove('hidden'); inn.classList.toggle('from-left',!fwd);
    void inn.offsetWidth;                     // reinicia la animacion de entrada
    inn.style.animation='none'; void inn.offsetWidth; inn.style.animation='';
  },190);
  saveRoute();
}
/* cambia de subseccion sin animacion (se usa al restaurar tras F5) */
function setTabDirect(name){
  if(TABS.indexOf(name)<0) return;
  clearTimeout(tabAnim);
  TABS.forEach(function(x){ var el=document.getElementById('tab-'+x);
    el.classList.toggle('hidden', x!==name); el.classList.remove('tab-out','to-right','from-left'); });
  document.querySelectorAll('#seg button').forEach(function(b){
    var on=b.dataset.tab===name; b.classList.toggle('active',on); b.setAttribute('aria-selected',on?'true':'false'); });
  currentTab=name;
  renderTab(name);
  moveSegIndicator();
  updateFocusLabel();
  pulseProfile();
}
/* restaura seccion + subseccion desde la URL (o localStorage) */
function restoreRoute(smooth){
  var r=readRoute();
  routing=true;
  if(r.page==='herramientas'){
    showPage('herramientas');
    setTabDirect(r.tab||'auto');
    if(r.tab) enterFocus(); else exitFocusSilent();
    routing=false; saveRoute();
    if(smooth){ setTimeout(function(){
      var seg=document.querySelector('#page-herramientas .tools-hero');
      if(seg) window.scrollTo({top:0,behavior:'smooth'});
    },50); }
    return;
  }
  showPage(r.page==='nosotros' ? 'nosotros' : 'inicio');
  routing=false; saveRoute();
}

/* ============ matches ============ */
const jobsEl = document.getElementById('jobs');
function sortedJobs(){ if(!analyzed) return JOBS; return [...JOBS].sort(function(a,b){ return (typeof (scores[b.id]||{}).score==='number'?scores[b.id].score:-1)-(typeof (scores[a.id]||{}).score==='number'?scores[a.id].score:-1); }); }
function render(){
  const list=sortedJobs(); const topId=analyzed&&list[0]?list[0].id:null;
  jobsEl.innerHTML = list.map(function(job,idx){
    const s=scores[job.id]; const has=s&&typeof s.score==='number'; const st=has?scoreStyle(s.score):null;
    const applied=appliedIds.has(job.id); const sel=selectedIds.has(job.id); const isTop=has&&job.id===topId&&s.score>=50;
    const c=jc(job.id);
    let col; if(s&&s.loading) col='<div class="score-empty">'+I.loader+'</div>'; else if(has) col=ring(s.score,st)+'<span class="score-tag" style="background:'+st.bg+';color:'+st.fg+'">'+st.label+'</span>'; else col='<div class="score-empty">'+t('noscore')+'</div>';
    let body; if(s&&s.loading) body='<div class="ph" style="width:80%"></div><div class="ph" style="width:55%"></div>'; else if(s&&s.reasons) body='<ul class="reasons">'+s.reasons.map(function(r){return '<li><span class="dash" style="background:'+st.fg+'"></span><span>'+r+'</span></li>';}).join('')+'</ul>'; else body='';
    return '<article class="job'+(isTop?' top-match':'')+(sel?' selected':'')+'" style="animation-delay:'+(idx*0.05)+'s"><div class="job-main">'+
      (isTop?'<span class="top-flag">'+t('best')+'</span>':'')+
      '<div class="titlerow"><h3>'+c.title+'</h3>'+(job.isPartner?'<span class="partner">'+t('partner')+'</span>':'')+'</div>'+
      '<p class="company">'+job.company+'</p><div class="meta"><span>'+I.pin+' '+c.location+'</span><span>'+I.wallet+' '+job.salary+'</span></div>'+body+'</div>'+
      '<div class="score-col">'+col+'</div>'+
      '<div class="job-actions"><button class="btn btn-blue btn-sm" style="'+(applied?'background:var(--green-soft);color:var(--green)':'')+'" '+(applied?'disabled':'')+' onclick="openApply('+job.id+')">'+(applied?I.check+' '+t('applied'):t('apply_btn'))+'</button>'+
      (applied?'':'<label class="selbox"><input type="checkbox" '+(sel?'checked':'')+' onchange="toggleSelect('+job.id+',this.checked)"> '+t('sumsel')+'</label>')+'</div></article>';
  }).join('');
  requestAnimationFrame(function(){ document.querySelectorAll('.ring-fg').forEach(function(el){ el.style.strokeDashoffset=el.dataset.off; }); });
  renderBatchBar();
}
function toggleSelect(id,ck){ if(ck) selectedIds.add(id); else selectedIds.delete(id); render(); }
function clearSelection(){ selectedIds.clear(); render(); }
function renderBatchBar(){ const bar=document.getElementById('batchBar'); const n=selectedIds.size; if(n===0){ bar.innerHTML=''; return; }
  bar.innerHTML='<div class="batchbar"><div class="bb-text">'+tf('batch_text',{n:n,s:(n>1?(lang==='fr'?'s':'s'):'')})+'</div><div class="bb-actions"><button class="link-btn" onclick="clearSelection()">'+t('batch_clear')+'</button><button class="btn btn-blue btn-sm" onclick="openBatchApply()">'+tf('batch_btn',{n:n})+'</button></div></div>'; }
function openBatchApply(){ batchJobs=JOBS.filter(function(j){return selectedIds.has(j.id);}); if(!batchJobs.length) return; let step=0; drawBatchModal(step); clearInterval(fillTimer);
  fillTimer=setInterval(function(){ step++; drawBatchModal(step); if(step>=batchJobs.length){ clearInterval(fillTimer); batchJobs.forEach(function(j){appliedIds.add(j.id);}); selectedIds.clear(); render(); } },480); }
function drawBatchModal(step){ const rows=batchJobs.map(function(j,i){ const f=i<step; return '<div class="field'+(f?' filled':'')+'"><span class="fl">'+jc(j.id).title+' · '+j.company+'</span><span class="fv">'+(f?I.check+' '+t('batch_ready'):'···')+'</span></div>'; }).join('');
  const done=step>=batchJobs.length;
  const footer=done?'<div class="modal-done"><div class="tick"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6L9 17l-5-5"/></svg></div><p>'+tf('batch_done',{n:batchJobs.length})+'</p><span class="note">'+t('batch_note')+'</span><button class="btn btn-blue block" onclick="closeModal()">'+t('entendido')+'</button></div>':'<p class="filling-note">'+I.loader+' '+t('filling')+'</p>';
  document.getElementById('modalRoot').innerHTML='<div class="overlay" onclick="if(event.target===this)closeModal()"><div class="modal"><div class="modal-head"><div><div class="m-kick">'+t('batch_kick')+'</div><h3>'+tf('batch_title',{n:batchJobs.length})+'</h3></div><button class="xbtn" onclick="closeModal()">'+I.x+'</button></div><p class="modal-sub">'+t('batch_sub')+'</p><div class="fields">'+rows+'</div>'+footer+'</div></div>'; }
async function analyzeAll(){ if(analyzing) return; const profile=document.getElementById('profile').value.trim(); if(!profile) return;
  analyzing=true; analyzed=true; const btn=document.getElementById('analyzeBtn'),lbl=document.getElementById('analyzeLabel'); btn.disabled=true; lbl.textContent=t('m_analyzing');
  document.getElementById('stats').classList.remove('hidden'); JOBS.forEach(function(j){ scores[j.id]={loading:true}; }); render(); updateStats();
  await Promise.all(JOBS.map(function(job,i){ return new Promise(function(res){ setTimeout(function(){ const r=computeScore(profile,job); scores[job.id]={score:r.score,reasons:r.reasons,loading:false}; render(); updateStats(); res(); }, 400+i*280+Math.random()*220); }); }));
  analyzing=false; btn.disabled=false; lbl.textContent=t('m_again'); render(); updateStats(); }
function updateStats(){ const v=Object.keys(scores).map(function(k){return scores[k];}); document.getElementById('scored').textContent=v.filter(function(s){return typeof s.score==='number';}).length; document.getElementById('excellent').textContent=v.filter(function(s){return s.score>=80;}).length; }

/* ============ autopilot ============ */
function togglePref(type,val,el){ const key=type==='mod'?'mod':'jor'; if(prefs[key].has(val)) prefs[key].delete(val); else prefs[key].add(val); el.classList.toggle('active'); }
function prefMatch(j){ const m=prefs.mod.size===0||prefs.mod.has(j.mod); const jj=prefs.jor.size===0||prefs.jor.has(j.jor); return m&&jj; }
function runAutopilot(){ const profile=document.getElementById('profile').value.trim(); if(!profile){ alert(t('ap_noprofile')); return; }
  apJobs=JOBS.filter(prefMatch); apJobs.forEach(function(j){ const r=computeScore(profile,j); scores[j.id]={score:r.score,reasons:r.reasons,loading:false}; }); apJobs.sort(function(a,b){return scores[b.id].score-scores[a.id].score;});
  analyzed=true; render(); updateStats(); document.getElementById('stats').classList.remove('hidden');
  if(!apJobs.length){ document.getElementById('modalRoot').innerHTML='<div class="overlay" onclick="if(event.target===this)closeModal()"><div class="modal"><div class="modal-head"><div><div class="m-kick">'+t('ap_kick')+'</div><h3>'+t('ap_nojobs_t')+'</h3></div><button class="xbtn" onclick="closeModal()">'+I.x+'</button></div><p class="modal-sub">'+t('ap_nojobs_p')+'</p><button class="btn btn-blue block" onclick="closeModal()">'+t('close')+'</button></div></div>'; return; }
  let phase='scan',sIdx=0,jIdx=0; drawAP('scan',{sIdx:0,jIdx:0}); clearInterval(apTimer);
  apTimer=setInterval(function(){ if(phase==='scan'){ sIdx++; if(sIdx>SOURCES.length){ phase='apply'; jIdx=0; drawAP('apply',{sIdx:sIdx,jIdx:jIdx}); } else drawAP('scan',{sIdx:sIdx,jIdx:jIdx}); } else if(phase==='apply'){ jIdx++; if(jIdx>apJobs.length){ phase='done'; clearInterval(apTimer); apJobs.forEach(function(j){appliedIds.add(j.id);}); render(); updateStats(); drawAP('done',{sIdx:sIdx,jIdx:jIdx}); } else drawAP('apply',{sIdx:sIdx,jIdx:jIdx}); } },460); }
function drawAP(phase,st){ let head='',body='';
  if(phase==='scan'){ const rows=SOURCES.map(function(sn,i){ const d=i<st.sIdx,c=i===st.sIdx; return '<div class="field'+(d?' filled':'')+'"><span class="fl">'+sn+'</span><span class="fv">'+(d?I.check+' '+t('ap_revised'):(c?I.loader+' '+t('ap_searching'):t('ap_queue')))+'</span></div>'; }).join('');
    head='<div class="modal-head"><div><div class="m-kick">'+t('ap_kick')+'</div><h3>'+t('ap_scan_t')+'</h3></div><button class="xbtn" onclick="closeModal()">'+I.x+'</button></div><p class="modal-sub">'+t('ap_scan_p')+'</p>'; body='<div class="fields">'+rows+'</div>'; }
  else if(phase==='apply'){ const rows=apJobs.map(function(j,i){ const d=i<st.jIdx; return '<div class="field'+(d?' filled':'')+'"><span class="fl">'+jc(j.id).title+' · '+j.company+'</span><span class="fv">'+(d?I.check+' '+t('ap_sent'):'···')+'</span></div>'; }).join('');
    head='<div class="modal-head"><div><div class="m-kick">'+t('ap_kick')+'</div><h3>'+tf('ap_apply_t',{n:apJobs.length})+'</h3></div><button class="xbtn" onclick="closeModal()">'+I.x+'</button></div><p class="modal-sub">'+t('ap_apply_p')+'</p>'; body='<div class="fields">'+rows+'</div>'; }
  else { body='<div class="modal-done"><div class="tick"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6L9 17l-5-5"/></svg></div><p>'+tf('ap_done',{n:apJobs.length})+'</p><span class="note">'+t('ap_done_note')+'</span><button class="btn btn-blue block" onclick="closeModal()">'+t('ap_ready_btn')+'</button></div>'; }
  document.getElementById('modalRoot').innerHTML='<div class="overlay" onclick="if(event.target===this)closeModal()"><div class="modal">'+head+body+'</div></div>'; }

/* ============ adapter ============ */
/* Ofertas, CV a medida y Entrevista comparten la MISMA lista de puestos */
function jobOptions(sel){
  return JOBS.map(function(j){
    return '<option value="'+j.id+'"'+(String(j.id)===String(sel)?' selected':'')+'>'+jc(j.id).title+' · '+j.company+'</option>';
  }).join('');
}
function fillJobSelects(){
  var rprev=document.getElementById('roleSel').value;
  document.getElementById('roleSel').innerHTML=jobOptions(rprev);
  var aprev=document.getElementById('adapterSel').value;
  document.getElementById('adapterSel').innerHTML='<option value=""'+(aprev?'':' selected')+'>'+t('ad_placeholder')+'</option>'+jobOptions(aprev);
}
/* puntaje general cuando no hay puesto elegido: mide que tan solido esta el CV en si mismo */
function genericScore(profile){
  var txt=(profile||'').trim(); if(!txt) return 0;
  var sk=detectedSkills(txt).length;
  var hasNums=/\d+\s*%|[+]\d|\b\d{2,}\b/.test(txt);
  var hasYears=!!cvYears(txt);
  var words=txt.split(/\s+/).length;
  var score=28 + Math.min(sk,8)*4 + (hasNums?12:0) + (hasYears?10:0) + Math.min(Math.floor(words/60),4)*4;
  return Math.max(20, Math.min(88, score));
}
function renderAdapter(){
  const v=document.getElementById('adapterSel').value;
  const body=document.getElementById('adapterBody');
  const profile=document.getElementById('profile').value;
  const hint=document.getElementById('adapterHint');
  if(hint) hint.classList.toggle('dimmed', v!=='' && v!=null);

  /* --- sin puesto: no bloqueamos nada, adaptamos en modo general --- */
  if(v===''||v==null){
    if(!profile.trim()){ body.innerHTML='<div class="card" style="text-align:center;color:var(--ink-2);font-size:15px;padding:28px">'+t('imp_empty')+'</div>'; return; }
    var sk=detectedSkills(profile);
    var kwHas=sk.length? sk.map(function(k){return '<span class="kw has">'+k+'</span>';}).join('')
                       : '<span style="font-size:13px;color:var(--ink-3)">'+t('cv_ph_skills')+'</span>';
    var gsum=tf('ad_sum_generic',{skills:'<span class="ins">'+(sk.slice(0,5).join(', ')||t('ad_yourarea'))+'</span>'});
    body.innerHTML=
      '<div class="generic-note"><svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 16v-4M12 8h.01"/></svg>'+
        '<span>'+t('ad_generic_note')+'</span></div>'+
      '<div class="kw-box" style="margin-bottom:14px"><h5 style="color:var(--green)">'+t('ad_has_generic')+'</h5><div class="kw-list">'+kwHas+'</div></div>'+
      '<div class="adapted"><span class="tape">'+t('ad_tape_generic')+'</span><h5>'+t('ad_sumtitle')+'</h5><p>'+gsum+'</p>'+
      '<div class="base-note">'+t('ad_basenote')+'</div></div>'+
      adapterExtras();
    return;
  }
  const job=jobById(v); if(!job){ body.innerHTML=''; return; }
  const r=computeScore(profile,{id:1,skills:job.skills}); const roleName=jc(job.id).title;
  const hasKw=r.matched.map(function(k){return '<span class="kw has">'+cap(k)+'</span>';}).join('')||'<span style="font-size:13px;color:var(--ink-3)">—</span>';
  const missKw=r.missing.map(function(k){return '<span class="kw miss">'+cap(k)+'</span>';}).join('')||'<span style="font-size:13px;color:var(--ink-3)">'+t('ad_all')+'</span>';
  const already=r.matched.map(cap).join(", "); const toAdd=r.missing.map(cap);
  let adapted=tf('ad_sum1',{role:'<span class="ins">'+roleName+'</span>',skills:(already||t('ad_yourarea'))});
  if(toAdd.length) adapted+=tf('ad_sum2',{add:toAdd.map(function(k){return '<span class="ins">'+k+'</span>';}).join(', ')});
  adapted+=t('ad_sum3');
  body.innerHTML='<div class="kw-grid"><div class="kw-box"><h5 style="color:var(--green)">'+t('ad_has')+'</h5><div class="kw-list">'+hasKw+'</div></div><div class="kw-box"><h5 style="color:var(--amber)">'+t('ad_add')+'</h5><div class="kw-list">'+missKw+'</div></div></div><div class="adapted"><span class="tape">'+t('ad_tape')+roleName+'</span><h5>'+t('ad_sumtitle')+'</h5><p>'+adapted+'</p><div class="base-note">'+t('ad_basenote')+'</div></div>'+adapterExtras(); }

/* ============ analysis + improved CV ============ */
function setReader(r){
  if(!READERS[r]) return;
  currentReader=r;
  document.querySelectorAll('#readerToggle [data-reader]').forEach(function(b){
    var on=b.dataset.reader===r;
    b.classList.toggle('active',on);
    b.setAttribute('aria-checked',on?'true':'false');
  });
  renderAnalysis();                       // el diagnostico se regenera con el evaluador elegido
  var body=document.getElementById('analysisBody');
  if(body){ body.style.animation='none'; void body.offsetWidth; body.style.animation='tabIn .35s cubic-bezier(.2,.7,.2,1) both'; }
}
function renderAnalysis(){ const profile=document.getElementById('profile').value; const sk=detectedSkills(profile);
  setTimeout(renderCvEditBtn,0);
  const strengths=[]; if(sk.length>=4) strengths.push(tf('str1a',{list:sk.slice(0,4).join(", ")})); else if(sk.length) strengths.push(tf('str1b',{list:sk.join(", ")})); else strengths.push(t('str1c'));
  strengths.push(t('str2')); strengths.push(t('str3'));
  const weak=[t('wea1'),t('wea2'),t('wea3')];
  document.getElementById('analysisBody').innerHTML=
    '<div class="sw-grid"><div class="sw-box str"><h5>'+t('str_title')+'</h5><ul>'+strengths.map(function(s){return '<li><b style="color:var(--green)">+</b><span>'+s+'</span></li>';}).join('')+'</ul></div>'+
    '<div class="sw-box wea"><h5>'+t('wea_title')+'</h5><ul>'+weak.map(function(s){return '<li><b style="color:var(--amber)">!</b><span>'+s+'</span></li>';}).join('')+'</ul></div></div>'+
    '<div class="format-tip"><h5>'+t('fmt_title')+t(READER_NAME[currentReader])+'</h5><p>'+readerTip(currentReader)+'</p></div>'+
    buildImprovedCV(profile); }
/* ===== Localizacion semantica del CV (ES <-> EN) =====
   No es palabra por palabra: glosario de cargos, tecnicismos academicos y giros de CV,
   aplicado de frase mas larga a mas corta. El resultado queda editable por el usuario. */
var CV_GLOSS = [
  /* cargos y ambito academico */
  ["profesor ayudante","teaching assistant"],["ayudante de catedra","teaching assistant"],["ayudante de cátedra","teaching assistant"],
  ["auxiliar docente","teaching assistant"],["jefe de trabajos practicos","teaching assistant"],
  ["asistente de investigacion","research assistant"],["asistente de investigación","research assistant"],
  ["promedio academico","academic average"],["promedio académico","academic average"],["promedio general","grade point average"],
  ["mejor promedio","top of class"],["cuadro de honor","dean's list"],["abanderado","valedictorian"],
  ["licenciatura en","bachelor's degree in"],["licenciado en","bachelor's degree in"],["licenciada en","bachelor's degree in"],
  ["ingenieria en","engineering degree in"],["ingeniería en","engineering degree in"],
  ["maestria en","master's degree in"],["maestría en","master's degree in"],["magister en","master's degree in"],
  ["tecnicatura en","technical degree in"],["diplomatura en","certificate in"],["posgrado en","postgraduate studies in"],
  ["beca de merito","merit scholarship"],["beca de mérito","merit scholarship"],["beca","scholarship"],
  ["tesis de grado","undergraduate thesis"],["tesis","thesis"],["trabajo final","capstone project"],
  ["universidad","university"],["facultad de","school of"],["colegio","high school"],["escuela","school"],
  ["carrera","degree programme"],["materia","course"],["catedra","course"],["cátedra","course"],
  ["intercambio academico","academic exchange"],["intercambio académico","academic exchange"],
  ["practica profesional","professional internship"],["práctica profesional","professional internship"],
  ["pasantia","internship"],["pasantía","internship"],["voluntariado","volunteering"],
  /* puestos frecuentes */
  ["desarrollador full stack","full stack developer"],["desarrolladora full stack","full stack developer"],
  ["desarrollador frontend","frontend developer"],["desarrollador backend","backend developer"],
  ["desarrollador de software","software developer"],["analista de datos","data analyst"],
  ["analista de producto","product analyst"],["analista funcional","business analyst"],
  ["gerente de proyecto","project manager"],["jefe de proyecto","project lead"],["lider de equipo","team lead"],["líder de equipo","team lead"],
  ["responsable de","head of"],["encargado de","in charge of"],["pasante","intern"],["becario","intern"],
  ["consultor","consultant"],["asesor","advisor"],["docente","lecturer"],["capacitador","trainer"],
  ["diseñador ux","ux designer"],["diseñadora ux","ux designer"],["gerente comercial","sales manager"],
  ["representante de ventas","sales representative"],["atencion al cliente","customer support"],["atención al cliente","customer support"],
  ["recursos humanos","human resources"],["marketing digital","digital marketing"],["independiente","freelance"],
  /* vocabulario academico y corporativo frecuente en CVs */
  ["clases practicas","lab sessions"],["clases prácticas","lab sessions"],["clase practica","lab session"],
  ["trabajos practicos","problem sets"],["trabajos prácticos","problem sets"],["clases teoricas","lectures"],["clases teóricas","lectures"],
  ["analisis de datos","data analysis"],["análisis de datos","data analysis"],["ciencia de datos","data science"],
  ["desarrollo web","web development"],["desarrollo de software","software development"],["base de datos","database"],
  ["bases de datos","databases"],["aprendizaje automatico","machine learning"],["aprendizaje automático","machine learning"],
  ["inteligencia artificial","artificial intelligence"],["redes sociales","social media"],["campaña","campaign"],
  ["campañas","campaigns"],["presupuesto","budget"],["informes","reports"],["informe","report"],["reportes","reports"],["reporte","report"],
  ["tablero","dashboard"],["tableros","dashboards"],["indicadores","KPIs"],["metricas","metrics"],["métricas","metrics"],
  ["cierre mensual","monthly close"],["cierre","close"],["mensual","monthly"],["semanal","weekly"],["trimestral","quarterly"],["anual","annual"],
  ["procesos","processes"],["proceso","process"],["tareas","tasks"],["herramientas","tools"],["plataforma","platform"],
  ["interfaces","interfaces"],["interfaz","interface"],["aplicacion","application"],["aplicación","application"],
  ["capacitaciones","training sessions"],["capacitacion","training"],["capacitación","training"],
  ["investigacion","research"],["investigación","research"],["publicacion","publication"],["publicación","publication"],
  ["congreso","conference"],["seminario","seminar"],["taller","workshop"],["curso","course"],["cursos","courses"],
  ["certificacion","certification"],["certificación","certification"],["examenes","exams"],["exámenes","exams"],
  ["evaluacion","assessment"],["evaluación","assessment"],["correccion","grading"],["corrección","grading"],
  ["semestre","semester"],["cuatrimestre","term"],["alumnos","students"],["alumnas","students"],["estudiantes","students"],
  ["estudiante","student"],["alumno","student"],["ayudantes","teaching assistants"],["ayudante","teaching assistant"],
  ["materias","courses"],["ejercicios","exercises"],["consignas","assignments"],["contenidos","content"],["contenido","content"],
  ["negocios digitales","digital business"],["administracion de empresas","business administration"],["administración de empresas","business administration"],
  ["economia","economics"],["economía","economics"],["contabilidad","accounting"],["finanzas","finance"],
  ["ingenieria industrial","industrial engineering"],["ingeniería industrial","industrial engineering"],
  ["ingenieria en sistemas","systems engineering"],["ingeniería en sistemas","systems engineering"],
  ["ciencias de la computacion","computer science"],["ciencias de la computación","computer science"],
  ["derecho","law"],["psicologia","psychology"],["psicología","psychology"],["diseño","design"],["arquitectura","architecture"],
  ["avanzado","advanced"],["intermedio","intermediate"],["basico","basic"],["básico","basic"],["fluido","fluent"],
  ["ajedrez","chess"],["fotografia","photography"],["fotografía","photography"],["ciclismo","cycling"],["musica","music"],["música","music"],
  ["deportes","sports"],["viajes","travel"],["lectura","reading"],["natacion","swimming"],["natación","swimming"],
  ["mentor","mentor"],["mentoria","mentoring"],["mentoría","mentoring"],["freelance","freelance"],
  ["tiempo de","time to"],["tiempo","time"],["personas","people"],["area","area"],["área","area"],["puesto","role"],["cargo","role"],
  ["remoto","remote"],["hibrido","hybrid"],["híbrido","hybrid"],["presencial","on-site"],
  ["jornada completa","full-time"],["media jornada","part-time"],["por cuenta propia","self-employed"],
  /* verbos de logro (primera persona) */
  ["coordine","coordinated"],["coordiné","coordinated"],["lidere","led"],["lideré","led"],["dirigi","directed"],["dirigí","directed"],
  ["desarrolle","developed"],["desarrollé","developed"],["implemente","implemented"],["implementé","implemented"],
  ["diseñe","designed"],["diseñé","designed"],["construi","built"],["construí","built"],["arme","built"],["armé","built"],
  ["cree","created"],["creé","created"],["gestione","managed"],["gestioné","managed"],["administre","managed"],["administré","managed"],
  ["optimice","optimised"],["opticé","optimised"],["optimicé","optimised"],["mejore","improved"],["mejoré","improved"],
  ["reduje","reduced"],["aumente","increased"],["aumenté","increased"],["automatice","automated"],["automaticé","automated"],
  ["analice","analysed"],["analicé","analysed"],["colabore","collaborated"],["colaboré","collaborated"],
  ["participe","took part"],["participé","took part"],["presente","presented"],["presenté","presented"],
  ["capacite","trained"],["capacité","trained"],["supervise","supervised"],["supervisé","supervised"],
  ["logre","achieved"],["logré","achieved"],["consegui","secured"],["conseguí","secured"],["escribi","wrote"],["escribí","wrote"],
  /* giros de CV */
  ["responsable del","responsible for the"],["a cargo de","in charge of"],["encargada de","in charge of"],
  ["experiencia en","experience in"],["conocimientos en","knowledge of"],["manejo de","proficiency in"],
  ["trabajo en equipo","teamwork"],["equipos agiles","agile teams"],["equipos ágiles","agile teams"],["metodologias agiles","agile methodologies"],["metodologías ágiles","agile methodologies"],
  ["orientado a resultados","results-driven"],["orientada a resultados","results-driven"],
  ["de punta a punta","end-to-end"],["impacto de negocio","business impact"],["mejora continua","continuous improvement"],
  ["toma de decisiones","decision-making"],["resolucion de problemas","problem solving"],["resolución de problemas","problem solving"],
  ["atencion al detalle","attention to detail"],["atención al detalle","attention to detail"],
  ["comunicacion","communication"],["comunicación","communication"],["liderazgo","leadership"],["idiomas","languages"],
  ["nivel avanzado","advanced level"],["nivel intermedio","intermediate level"],["nivel basico","basic level"],["nivel básico","basic level"],
  ["nativo","native"],["ingles","english"],["inglés","english"],["español","spanish"],["frances","french"],["francés","french"],["portugues","portuguese"],["portugués","portuguese"],
  ["actualmente","currently"],["actualidad","present"],["presente","present"],["hasta hoy","to date"],
  ["años de experiencia","years of experience"],["anos de experiencia","years of experience"],["año","year"],["años","years"],
  ["clientes","clients"],["usuarios","users"],["ventas","sales"],["ingresos","revenue"],["equipo de","team of"],
  ["empresa","company"],["proyecto","project"],["proyectos","projects"],["logros","achievements"],
  ["referencias disponibles","references available upon request"],
  /* conectores minimos (evitan el spanglish crudo en las viñetas) */
  ["a traves de","through"],["a través de","through"],["ademas","also"],["además","also"],["mediante","through"],
  ["para","for"],["desde","since"],["hasta","until"],["entre","between"],["sobre","on"],["junto a","alongside"],
  ["con","with"],["sin","without"],["y","and"],["e","and"],["o","or"],["del","of the"],["de la","of the"],["de","of"],
  ["en","in"],["un","a"],["una","a"],["los","the"],["las","the"],["el","the"],["la","the"],["que","that"],["mas","more"],["más","more"]
];
function cvCapLike(src,out){ return /^[A-ZÁÉÍÓÚÑ]/.test(src) ? out.charAt(0).toUpperCase()+out.slice(1) : out; }
function cvEsc4Rx(x){ return x.replace(/[.*+?^${}()|[\]\\]/g,'\\$&'); }
var _cvRxCache={};
function cvGlossRx(term){ if(!_cvRxCache[term]) _cvRxCache[term]=new RegExp('(^|[^\\wÁÉÍÓÚÑáéíóúñ])('+cvEsc4Rx(term)+')(?![\\wÁÉÍÓÚÑáéíóúñ])','gi'); return _cvRxCache[term]; }
function cvTranslateText(txt, from, to){
  if(!txt || from===to) return txt||'';
  var pairs = CV_GLOSS.map(function(p){ return from==='es' ? {a:p[0],b:p[1]} : {a:p[1],b:p[0]}; })
    .sort(function(x,y){ return y.a.length-x.a.length; });   // frase larga primero: contexto antes que palabra suelta
  var out=' '+txt+' ';
  pairs.forEach(function(pr){
    out=out.replace(cvGlossRx(pr.a), function(m,pre,hit){ return pre+cvCapLike(hit,pr.b); });
  });
  out=cvTidy(out,to);
  return out.replace(/\s{2,}/g,' ').trim();
}
/* pasada de limpieza: evita el "spanglish" mecanico de la sustitucion */
function cvTidy(x,to){
  var o=' '+x+' ';
  if(to==='en'){
    o=o.replace(/\b(a|the|of|in|and|for|with|that|more)\s+\1\b/gi,'$1')      // "a a", "the the"
       .replace(/\b(english|spanish|french|portuguese|german|italian)\s+(advanced|intermediate|basic|fluent|native)\b/gi,
                function(m,l,v){ return v.charAt(0).toUpperCase()+v.slice(1).toLowerCase()+' '+l.charAt(0).toUpperCase()+l.slice(1).toLowerCase(); })
       .replace(/\bstudent of ([A-Za-z][\w'’ ]{2,30}?)(?=[,.;]|\s+(?:results-driven|with|focused|specialis|specializ))/gi,
                function(m,f){ return f.trim()+' student'; })
       .replace(/(\b\d),(\d\b)/g,'$1.$2')                                     // 9,1 -> 9.1
       .replace(/\ba\s+(\d+(?:[.,]\d+)?\s*%)/gi,'by $1')                     // "un 40%" -> "by 40%"
       .replace(/\bof\s+the\s+of\b/gi,'of the')
       .replace(/\ba\s+([aeiouAEIOU])/g,'an $1')                              // a/an
       .replace(/\bin\s+the\s+that\b/gi,'in which')
       .replace(/\s+([,.;:%])/g,'$1');
  } else {
    o=o.replace(/\b(de|el|la|los|las|y|con|para|en|un|una)\s+\1\b/gi,'$1')
       .replace(/\s+([,.;:%])/g,'$1');
  }
  return o.replace(/\s{2,}/g,' ').trim();
}
function cvTranslateModel(m, from, to){
  var c=JSON.parse(JSON.stringify(m));
  var T=function(x){ return cvTranslateText(x,from,to); };
  c.summary=T(c.summary); c.interests=T(c.interests);
  c.skills=(c.skills||[]).map(T);
  c.experience=(c.experience||[]).map(function(e){
    return { role:T(e.role), company:e.company, location:e.location||'', dates:T(e.dates), bullets:(e.bullets||[]).map(T) }; });
  c.education=(c.education||[]).map(function(e){
    return { title:T(e.title), detail:T(e.detail), location:e.location||'', dates:T(e.dates) }; });
  return c;
}
function cvDetectLang(txt){
  var p=' '+stripAccents(String(txt||'').toLowerCase())+' ';
  var es=(p.match(/\s(de|la|el|los|las|con|para|experiencia|anos|y|en|un|una|del)\s/g)||[]).length;
  var en=(p.match(/\s(the|of|and|with|for|experience|years|a|in|to)\s/g)||[]).length;
  return en>es ? 'en' : 'es';
}
/* aplica el idioma de la interfaz al CV en pantalla, sin perder las ediciones */
function cvApplyLang(){
  if(!CVM) return;
  var view = (lang==='en') ? 'en' : (lang==='es' ? 'es' : null);   // ES <-> EN
  if(!view) return;                                                 // fr/pt: no se toca el contenido del usuario
  if(!CVM.base){ CVM.base=JSON.parse(JSON.stringify(CVM)); CVM.baseLang=CVM.textLang||cvDetectLang(CVM.summary+' '+(CVM.experience[0]?CVM.experience[0].bullets.join(' '):'')); }
  if(view===CVM.baseLang){                                           // volver al original del usuario
    var b=CVM.base; CVM.name=b.name; CVM.contactLine=b.contactLine; CVM.summary=b.summary;
    CVM.skills=b.skills.slice(); CVM.interests=b.interests;
    CVM.experience=JSON.parse(JSON.stringify(b.experience)); CVM.education=JSON.parse(JSON.stringify(b.education));
    CVM.viewLang=view; CVM.translated=false;
  } else {
    var tr=cvTranslateModel(CVM.base, CVM.baseLang, view);
    CVM.summary=tr.summary; CVM.skills=tr.skills; CVM.interests=tr.interests;
    CVM.experience=tr.experience; CVM.education=tr.education;
    CVM.viewLang=view; CVM.translated=true;
  }
  cvSaveModel();
}

/* ===== Motor de CV — parsing por bloques + plantilla ejecutiva EDITABLE (A4, serif) ===== */
function cvEscape(x){ return String(x==null?'':x).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;'); }

/* --- 1. Parsing: entiende el CV por secciones, no por adivinanza --- */
var CV_SEC_RX = {
  sum:/^(resumen|resumo|perfil|perfil profesional|professional summary|summary|profile|about( me)?|sobre m[ií]|objetivo|profil)\b/i,
  exp:/^(experiencia|experi[eê]ncia|experiencia (laboral|profesional)|work experience|professional experience|experience|exp[ée]rience|trayectoria|historial laboral|empleo)\b/i,
  edu:/^(educaci[oó]n|educa[cç][aã]o|formaci[oó]n|formation|education|estudios|acad[eé]mic|escolaridad)/i,
  skl:/^(habilidades|competencias|compet[eê]ncias|comp[ée]tences|skills|technical skills|conocimientos|tecnolog[ií]as|stack|herramientas)\b/i,
  int:/^(intereses|interesses|interests|int[eé]r[eê]ts|centres d'int[eé]r[eê]t|hobbies|otros|extra)\b/i,
  cert:/^(certificaciones|certifica[cç][õo]es|certifications|certificados|cursos|courses|capacitaciones|formaci[oó]n complementaria|diplomas)\b/i,
  lang:/^(idiomas|languages|langues|l[ií]nguas)\b/i
};
function cvIsHeader(line){
  var l=line.replace(/[:：]\s*$/,'').trim();
  if(!l || l.length>42 || l.split(/\s+/).length>5) return null;
  for(var k in CV_SEC_RX){ if(CV_SEC_RX[k].test(l)) return k; }
  return null;
}
var CV_MONTH='(?:ene|feb|mar|abr|may|jun|jul|ago|sep|set|oct|nov|dic|jan|apr|aug|dec|janv|f\u00e9vr|avr|juil|ao\u00fbt|d\u00e9c)\\w*\\.?\\s*(?:de\\s+)?';
var CV_NUMDATE_RX=/\b(0?[1-9]|1[0-2])\/((?:19|20)\d{2})\s*(?:[\u2013\-\u2014]|a|to)\s*(?:(0?[1-9]|1[0-2])\/((?:19|20)\d{2})|(actualidad|presente|present|current|hoy))/i;
var CV_RANGE_RX=new RegExp('('+CV_MONTH+')?\\b(19|20)\\d{2}\\b\\s*(?:[\u2013\\-\u2014/]|a|to|at\u00e9|au|y|and|et|e)\\s*('+CV_MONTH+')?((19|20)\\d{2}|actualidad|presente|present|current|actuel|aujourd\'hui|atual|hoy)','i');
var CV_YEAR_RX=/\b(19|20)\d{2}\b/;
var CV_TOKEN_RX=/(19|20)\d{2}|actualidad|presente|present|current|actuel|aujourd'hui|atual|hoy/gi;
function cvDateOf(x){
  var nd=String(x||'').match(CV_NUMDATE_RX);
  if(nd){
    var end = nd[3] ? nd[3]+'/'+nd[4] : (nd[5]||'').charAt(0).toUpperCase()+(nd[5]||'').slice(1);
    return nd[1]+'/'+nd[2]+' \u2013 '+end;
  }
  var r=String(x||'').match(CV_RANGE_RX);
  if(r){ var tk=r[0].match(CV_TOKEN_RX);           // se normaliza siempre a "2021 \u2013 2025"
    if(tk && tk.length>=2){ var b=tk[tk.length-1]; b=b.charAt(0).toUpperCase()+b.slice(1); return tk[0]+' \u2013 '+b; }
    return r[0].trim(); }
  var y=String(x||'').match(CV_YEAR_RX);
  return y? y[0].trim() : '';
}
function cvStripDate(x){
  var r=String(x||'').replace(CV_NUMDATE_RX,' ').replace(CV_RANGE_RX,' ').replace(CV_YEAR_RX,' ');
  var clean=/^[\s,;.:|·\-\u2013\u2014(]+|[\s,;.:|·\-\u2013\u2014()]+$/g;
  return r.replace(/\s{2,}/g,' ').replace(clean,'')
     .replace(/\s+\b(entre|between|desde|from|del|de|au|\u00e0|at\u00e9|e|y|and|et)\b$/i,'')
     .replace(clean,'').trim();
}
function cvIsBullet(l){ return /^[-•·*▪—–]\s+/.test(l); }
var CV_INST_RX=/(universidad|universidade|university|universit[ée]|instituto|institute|facultad|school|escuela|colegio|coll[eè]ge|academia|academy|utn|uba|udesa|itba|ort)/i;
var CV_DEGREE_RX=/(licenciatur|licenciad|ingenier|engineering|bachelor|b\.?[as]\.?|master|m[aá]ster|mba|maestr|doctorad|phd|t[eé]cnic|tecn[oó]log|diplomatur|certificad|certificat|certification|curso|course|capacitaci|posgrado|postgrad|grado|degree|secundari|bachiller|high school|abogac|contador|profesorado)/i;
var CV_LOC_CORE="(?:[A-Z\u00c0-\u00dd][\\w\u00c0-\u00ff.'-]+(?:\\s+[A-Z\u00c0-\u00dd][\\w\u00c0-\u00ff.'-]+)*,\\s*(?:Argentina|Chile|Uruguay|Brasil|Brazil|M[e\u00e9]xico|Espa[n\u00f1]a|Spain|Colombia|Per[u\u00fa]|USA|United States|UK|Francia|France|Portugal|Alemania|Germany|Italia|Italy|LatAm))|(?:Remoto|Remote|H[i\u00ed]brido|Hybrid|Buenos Aires|CABA|C[o\u00f3]rdoba|Rosario|Santiago|Montevideo|S[a\u00e3]o Paulo|Madrid|Barcelona|Lima|Bogot[a\u00e1]|Londres|London|Nueva York|New York)";
var CV_LOC_RX=new RegExp("(?:^|[,|\u2013\u2014]\\s*)("+CV_LOC_CORE+")(?=\\s*(?:$|[,|\u2013\u2014]))");
var CV_NOISE_RX=/^(intereses|interesses|interests|int[eé]r[eê]ts|hobbies|idiomas|languages|habilidades|competencias|skills|conocimientos|tecnolog[ií]as|stack|referencias|references|contacto|contact|email|tel[eé]fono|phone|linkedin|github|nota|note|asistente|chat)\s*[:\-–]/i;
function cvIsSkillList(l){                       /* "React, Node, SQL, Figma" no es un logro */
  var x=cvClean(l).replace(/\.$/,'');
  if(/[.!?]$/.test(cvClean(l)) && x.split(/\s+/).length>7) return false;
  var parts=x.split(/[,;·|]/).map(function(y){return y.trim();}).filter(Boolean);
  if(parts.length<2) return false;
  var short=parts.filter(function(y){ return y.split(/\s+/).length<=3; }).length;
  return short/parts.length>=0.8;                /* casi todos son terminos sueltos, no oraciones */
}
var CV_VERB_RX=/(?:[eé]|í|i)\b|\b(?:desarroll|implement|dise[nñ]|coordin|lider|gestion|administr|optimiz|mejor|reduj|aument|automatiz|analiz|colabor|particip|present|capacit|supervis|logr|consegu|constru|arm|cre|escrib|dirig|manag|led|lead|develop|design|implement|improv|reduc|increas|automat|analys|analyz|built|created|coordinat|support|deliver|launch|own|drove|drive)/i;
function cvIsAchievement(l){
  var x=cvClean(l).trim();
  if(x.length<12) return false;
  if(CV_NOISE_RX.test(x)) return false;          /* intereses / skills / notas del chat */
  if(cvIsSkillList(x)) return false;
  if(CV_INST_RX.test(x) && CV_DEGREE_RX.test(x)) return false;  /* linea de educacion colada */
  var words=x.split(/\s+/).length;
  return words>=4 && (CV_VERB_RX.test(x) || words>=7);
}
function cvPullLocation(x){                      /* devuelve {rest, loc} — solo si la ubicacion viene separada */
  var str=String(x||''); var m=str.match(CV_LOC_RX);
  if(!m) return { rest:str.trim(), loc:'' };
  var rest=str.replace(m[0],' ').replace(/\s{2,}/g,' ')
    .replace(/^[\s,;.|·\-\u2013\u2014]+|[\s,;.|·\-\u2013\u2014]+$/g,'').trim();
  return { rest:rest, loc:(m[1]||'').trim() };
}
function cvTrimPiece(x){ return String(x||'').replace(/^[\s,;.:|·\-\u2013\u2014]+|[\s,;.:|·\-\u2013\u2014]+$/g,'').trim(); }
function cvClean(l){ return l.replace(/^[-•·*▪—–]\s+/,'').trim(); }
function cvSplitHead(line){
  /* corta UNA sola vez: "Puesto — Empresa", "Empresa | Puesto", "Puesto en Empresa", "Puesto, Empresa" */
  var rx=/\s+[|\u2013\u2014]\s+|\s+-\s+|\s+@\s+|\s+\ben\b\s+|\s+\bat\b\s+|\s+\bchez\b\s+|,\s+/;
  var m=String(line||'').match(rx);
  if(!m) return { a:String(line||'').trim(), b:'' };
  var i=m.index;
  return { a:line.slice(0,i).trim(), b:line.slice(i+m[0].length).trim() };
}
function cvContactBits(txt){
  var email=(txt.match(/[\w.+-]+@[\w-]+\.[\w.-]+/)||[])[0]||'';
  var phone=(txt.match(/(?:\+?\d[\d ().-]{7,}\d)/)||[])[0]||'';
  var lk=(txt.match(/(?:https?:\/\/)?(?:www\.)?linkedin\.com\/[^\s,|)]+/i)||[])[0]||'';
  var gh=(txt.match(/(?:https?:\/\/)?(?:www\.)?github\.com\/[^\s,|)]+/i)||[])[0]||'';
  var web=(txt.match(/(?:https?:\/\/)[^\s,|)]+/i)||[])[0]||'';
  if(web && (web.indexOf('linkedin')>=0 || web.indexOf('github')>=0)) web='';
  return [email,phone,lk,gh,web].map(function(x){ return (x||'').trim().replace(/[.,;]$/,''); }).filter(Boolean);
}
var CV_DOCTITLE_RX=/^(curriculum\s*vitae|curr[ií]culum( vitae)?|cv|resume|r[ée]sum[ée]|hoja de vida|datos personales|personal details)\b/i;
/* ============================================================================
   REGLA DURA DEL MOTOR DE CV (equivale al system prompt del bot):
   Todo lo que se muestra o exporta sale EXCLUSIVAMENTE del texto del CV recibido.
   - Prohibido tomar datos de la cuenta de MatchApply (USER.name/email), de perfiles
     de ejemplo (CONTACT) o de cualquier otra fuente.
   - Prohibido inventar puestos, empresas, fechas, instituciones o habilidades.
   - Si un dato no esta en el CV, se deja vacio y se muestra un placeholder para que
     lo complete la persona. Nunca se rellena por inferencia.
   Unica excepcion declarada: el resumen profesional, que se redacta a partir de los
   datos reales detectados y queda marcado como borrador editable.
   ============================================================================ */
function cvGuessName(txt){
  var lines=String(txt||'').split(/\n/).map(function(x){return x.trim().replace(/^[-•·]\s*/,'');}).filter(Boolean);
  for(var i=0;i<Math.min(lines.length,5);i++){
    var l=lines[i], w=l.split(/\s+/);
    if(CV_DOCTITLE_RX.test(l) || cvIsHeader(l)) continue;                       // "Curriculum Vitae" no es un nombre
    if(/@|linkedin|github|https?:|\+\d/i.test(l)) continue;
    if(l.length<=48 && !/\d/.test(l) && w.length>=2 && w.length<=5 && /^[A-Z\u00c0-\u00dd]/.test(l)) return l;
  }
  return '';   // no figura en el CV -> se deja vacio. NUNCA se usa el nombre de la cuenta.
}
function cvYears(txt){ var m=txt.match(/(\d+)\s*(a[nñ]os?|years?|ans|anos)/i); return m?m[1]:null; }
function cvSentences(block){
  return block.replace(/\n+/g,' ').split(/(?<=[.;])\s+(?=[A-ZÁÉÍÓÚÑ])|;\s+/)
    .map(function(x){ return cvClean(x).replace(/\s{2,}/g,' ').trim(); })
    .filter(function(x){ return x.length>18; })
    .map(function(x){ return /[.!?]$/.test(x)? x : x+'.'; });
}
/* normaliza el texto crudo: PDF y DOCX suelen venir en una sola linea, sin saltos */
var CV_HEAD_WORDS='(?:resumen|resumo|perfil profesional|perfil|professional summary|summary|profile|objetivo|sobre m[ií]|experiencia laboral|experiencia profesional|experiencia|experi[eê]ncia|work experience|professional experience|experience|exp[ée]rience|trayectoria|educaci[oó]n|educa[cç][aã]o|formaci[oó]n acad[eé]mica|formaci[oó]n|formation|education|estudios|habilidades t[eé]cnicas|habilidades|competencias|compet[eê]ncias|comp[ée]tences|skills|technical skills|conocimientos|tecnolog[ií]as|stack t[eé]cnico|stack|intereses|interesses|interests|int[eé]r[eê]ts|hobbies|idiomas|languages|certificaciones|certifications|proyectos|projects|voluntariado)';
function cvPrep(raw){
  var t=String(raw||'').replace(/\r/g,'');
  t=t.replace(/^\s*(curriculum\s*vitae|curr[ií]culum(\s*vitae)?|hoja de vida|resume|r[ée]sum[ée])\b[\s:.\-–]*/i,'');  // titulo del documento
  t=t.replace(/[\u2022\u25AA\u25CF\u00B7\u2023\u2043]/g,'\n- ');                                      // viñetas -> lineas
  t=t.replace(new RegExp('(?:^|\\n)[ \\t]*('+CV_HEAD_WORDS+')[ \\t]*[:：]','gi'), '\n$1:\n');            // "EXPERIENCIA:" al inicio de linea
  t=t.replace(new RegExp('([.!?])\\s+('+CV_HEAD_WORDS+')\\s*[:：]','gi'), '$1\n$2:\n');                 // ...o tras fin de oracion
  t=t.replace(new RegExp('([.a-z0-9)])\\s+((?:'+CV_HEAD_WORDS+'))(?=\\s+[A-ZÁÉÍÓÚÑ])','g'), '$1\n$2\n');
  t=t.replace(/\s+(?=[\w.+-]+@[\w-]+\.[\w.-]+)/,'\n');                                                // el nombre queda solo en su linea
  /* nueva entrada: "Puesto — Empresa | fecha" pegado al final de la linea anterior */
  t=t.replace(/([.!?%])\s+(?=[A-ZÁÉÍÓÚÑ][^\n]{2,70}?\s*[|\u2013\u2014-]\s*(?:[a-zA-Z]{3,5}\.?\s*(?:de\s+)?)?(?:\d{1,2}\/)?(?:19|20)\d{2})/g,'$1\n');
  t=t.replace(/([a-z0-9)])\s+(?=(?:19|20)\d{2}\s*[\u2013\-\u2014]\s*(?:(?:19|20)\d{2}|actualidad|presente|present))/g,'$1\n');
  t=t.replace(/[ \t]{2,}/g,' ').replace(/\n{3,}/g,'\n\n');
  return t.trim();
}

/* devuelve el modelo estructurado del CV */
function cvParse(text){
  var txt=cvPrep(text);
  var name=cvGuessName(txt);
  var contact=cvContactBits(txt);
  var lines=txt.split(/\n/).map(function(x){return x.replace(/\s+$/,'');});
  var buckets={sum:[],exp:[],edu:[],skl:[],int:[],cert:[],lang:[],head:[]}, cur='head', found=false;
  lines.forEach(function(raw){
    var l=raw.trim(); if(!l) { buckets[cur].push(''); return; }
    var h=cvIsHeader(l);
    if(h){ cur=h; found=true;
      var inline=l.replace(/^[^:：]*[:：]\s*/,''); // "Skills: React, Node"
      if(inline && inline!==l) buckets[cur].push(inline);
      return; }
    buckets[cur].push(l);
  });
  var model={ name:name, contactLine:contact.join('  |  '), summary:'', experience:[], education:[], skills:[], interests:'' };

  /* --- experiencia: puesto / empresa / fechas / logros --- */
  function parseExp(arr){
    var out=[], cur=null;
    arr.forEach(function(l){
      if(!l){ return; }
      if(cvIsBullet(l)){ if(cur) cur.bullets.push(cvClean(l)); return; }
      var date=cvDateOf(l);
      var rest=cvStripDate(l);
      /* linea que es SOLO una fecha: pertenece a la entrada abierta */
      if(date && !rest){ if(cur && !cur.dates){ cur.dates=date; return; } if(cur){ cur={ role:'', company:'', dates:date, bullets:[] }; out.push(cur); return; } }
      if(date || !cur){
        var h=cvSplitHead(rest);
        cur={ role:h.a, company:h.b, dates:date, bullets:[] }; out.push(cur); return;
      }
      if(cur && !cur.role && rest){ cur.role=rest; return; }
      /* linea corta sin verbo despues del encabezado: es la empresa, no un logro */
      if(cur && !cur.company && rest.length<=52 && !/[.!?]$/.test(rest) && rest.split(/\s+/).length<=6) { cur.company=rest; return; }
      if(cur) cur.bullets.push(cvClean(l));
    });
    /* solo quedan logros profesionales: fuera skills sueltas, intereses, notas y lineas de educacion */
    out.forEach(function(e){
      var b=[];
      e.bullets.forEach(function(x){
        var parts = x.length>170 ? cvSentences(x) : [x];
        parts.forEach(function(y){
          y=cvClean(y).trim();
          if(!cvIsAchievement(y)) return;                        // filtrado estricto
          y=y.charAt(0).toUpperCase()+y.slice(1);
          b.push(/[.!?]$/.test(y)? y : y+'.');
        });
      });
      var seen={};
      e.bullets=b.filter(function(x){ var k=x.toLowerCase(); if(seen[k]) return false; seen[k]=1; return true; }).slice(0,8);
      var L=cvPullLocation(e.company||''); e.company=L.rest; if(L.loc && !e.location) e.location=L.loc;
      if(!e.location){ var L2=cvPullLocation(e.role||''); if(L2.loc){ e.role=L2.rest; e.location=L2.loc; } }
    });
    /* una entrada sin puesto ni empresa ni logros no aporta nada: se descarta */
    return out.filter(function(e){ return (e.role||e.company||e.bullets.length); });
  }
  /* Educacion formal y limpia: institucion, titulo, ubicacion y periodo. Nada mas. */
  function parseEdu(arr){
    var out=[], cur=null;
    var isNew=function(e){ return !e || (e.title && e.detail && e.dates); };
    var put=function(e,piece,date,loc){
      if(loc && !e.location) e.location=loc;
      if(date && !e.dates) e.dates=date;
      piece=cvTrimPiece(piece);
      if(!piece) return;
      if(CV_INST_RX.test(piece) && !e.title){ e.title=piece; return; }        // institucion
      if(CV_DEGREE_RX.test(piece) && !e.detail){ e.detail=piece; return; }    // titulo obtenido
      if(!e.title){ e.title=piece; return; }
      if(!e.detail){ e.detail=piece; return; }
      /* cualquier otra cosa (promedios, comentarios, notas sueltas) NO entra al CV */
    };
    arr.forEach(function(raw){
      var l=cvClean(raw||'').trim(); if(!l) return;
      if(CV_NOISE_RX.test(l)) return;                                          // notas / skills / intereses colados
      /* comentarios y frases sueltas no son formacion academica */
      if(!CV_INST_RX.test(l) && !CV_DEGREE_RX.test(l) && l.split(/\s+/).length>7) return;
      var date=cvDateOf(l);
      var noDate=cvStripDate(l);
      var L=cvPullLocation(noDate); var rest=L.rest, loc=L.loc;
      if(!rest && !date && !loc) return;
      if(date && !rest && !loc){                                               // linea que es solo fecha
        if(cur && !cur.dates){ cur.dates=date; return; }
        cur={ title:'', detail:'', location:'', dates:date }; out.push(cur); return;
      }
      var pieces=rest? rest.split(/\s+[|\u2013\u2014]\s+|\s+-\s+|,\s+/).map(function(x){return x.trim();}).filter(Boolean) : [];
      var startsEntry = isNew(cur) || CV_INST_RX.test(rest) || (date && cur && cur.dates);
      if(startsEntry){ cur={ title:'', detail:'', location:'', dates:'' }; out.push(cur); }
      pieces.forEach(function(pc){ put(cur,pc,'',''); });
      if(loc && !cur.location) cur.location=loc;
      if(date && !cur.dates) cur.dates=date;
    });
    /* solo entradas con sustancia academica */
    return out.filter(function(e){ return (e.title||e.detail) && (CV_INST_RX.test(e.title||'') || CV_DEGREE_RX.test(e.detail||'') || CV_DEGREE_RX.test(e.title||'')); })
              .map(function(e){ return { title:e.title||'', detail:e.detail||'', location:e.location||'', dates:e.dates||'' }; })
              .slice(0,5);
  }
  function parseSkills(arr){
    var raw=arr.join(', ');
    return raw.split(/[,;·|\/]|\s{2,}/).map(function(x){ return cvClean(x).trim(); })
      .filter(function(x){ return x.length>1 && x.length<34; }).slice(0,24);
  }

  if(found){
    /* MAPEO ESTRICTO: cada bloque alimenta SOLO su seccion nativa */
    model.summary=cvSentences(buckets.sum.join(' ')).join(' ').trim();
    model.experience=parseExp(buckets.exp);                       // puestos, empresas, fechas, logros
    model.education=parseEdu(buckets.edu.concat(buckets.cert));   // estudios y certificaciones/cursos
    model.skills=parseSkills(buckets.skl.concat(buckets.lang));   // habilidades e idiomas
    model.interests=buckets.int.join(' ').replace(/\s{2,}/g,' ').trim();   // solo intereses
  }
  /* --- fallback: CV en prosa, sin encabezados --- */
  var yrs=cvYears(txt);
  if(!found || (!model.experience.length && !model.education.length)){
    var body=txt;
    if(name) body=body.split(name).join(' ');
    contact.forEach(function(c){ body=body.split(c).join(' '); });
    body=body.replace(/^[\s.,;|·-]+/,'').replace(/\s{2,}/g,' ').trim();
    var eduRx=/(universidad|universidade|university|universit[ée]|instituto|facultad|licenciatur|ingenier|bachelor|master|m[aá]ster|mba|t[eé]cnic|tecn[oó]log|carrera|grado|degree|diplom|escuela|school)/i;
    var sents=cvSentences(body);
    var eduS=sents.filter(function(x){ return eduRx.test(x); });
    var intRx=/^(intereses|interesses|interests|hobbies|idiomas|languages)\s*[:\-–]/i;
    var intS=body.match(/(?:intereses|interesses|interests|int[eé]r[eê]ts|hobbies|voluntariado)\s*[:\-–]\s*([^\n.;]{3,140})/i);
    var expS=sents.filter(function(x){ return eduS.indexOf(x)<0 && !intRx.test(x) && cvIsAchievement(x); });
    if(!model.experience.length && expS.length){
      model.experience=[{ role:t('cv_role_generic'), company:'', dates:(yrs?tf('cv_years_exp',{y:yrs}):''), bullets:expS.slice(0,6) }];
    }
    if(!model.education.length && eduS.length){
      model.education=eduS.slice(0,3).map(function(x){
        var L=cvPullLocation(cvStripDate(x));
        return { title:L.rest.replace(/^(estudi[eé]|curs[eé]|i studied|graduated (from|in)|me gradu[eé] (de|en))\s+/i,'').replace(/[.,;]+$/,'').trim(),
                 detail:'', location:L.loc, dates:cvDateOf(x) };
      });
    }
    if(!model.interests && intS) model.interests=intS[1].trim();
  }
  /* skills: primero lo que el usuario escribio en su bloque, luego lo detectado en el texto. Nada inventado. */
  var seen={}, merged=[];
  model.skills.concat(detectedSkills(txt)).forEach(function(k){
    var key=stripAccents(String(k).toLowerCase()).trim();
    if(key && !seen[key]){ seen[key]=1; merged.push(String(k).trim()); }
  });
  /* si una skill ya esta contenida en otra mas especifica ("Inglés" dentro de "Inglés avanzado"), se descarta */
  merged=merged.filter(function(k,i){
    var kk=stripAccents(k.toLowerCase());
    return !merged.some(function(o,j){
      if(i===j) return false;
      var oo=stripAccents(o.toLowerCase());
      return oo.length>kk.length && (oo.indexOf(kk+' ')===0 || oo.indexOf(' '+kk)>=0);
    });
  });
  model.skills=merged.slice(0,20);
  if(!model.summary){
    model.summary=tf('imp_sum2',{ years:(yrs?tf('imp_years',{y:yrs}):''), skills:(model.skills.slice(0,5).join(', ')||t('ad_yourarea')) });
    model.autoSummary=true;
  }
  cvSanitize(model);
  model.lang=lang; model.edited=false;
  model.textLang=cvDetectLang(txt); model.baseLang=model.textLang; model.viewLang=model.textLang;
  model.base=JSON.parse(JSON.stringify({name:model.name,contactLine:model.contactLine,summary:model.summary,
    experience:model.experience,education:model.education,skills:model.skills,interests:model.interests}));
  return model;
}

/* --- saneamiento final: ningun dato termina en una seccion que no es la suya --- */
var CV_CONTACT_RX=/[\w.+-]+@[\w-]+\.[\w.-]+|linkedin\.com|github\.com|^\+?[\d ().-]{8,}$/i;
function cvSanitize(m){
  /* EXPERIENCIA: solo logros. Fuera contacto, skills sueltas, intereses, educacion y notas. */
  m.experience=(m.experience||[]).map(function(e){
    e.bullets=(e.bullets||[]).filter(function(b){
      if(CV_CONTACT_RX.test(b)) return false;                       // datos personales -> no van aca
      if(CV_INST_RX.test(b) && CV_DEGREE_RX.test(b)) return false;  // educacion -> no va aca
      if(cvIsSkillList(b)) return false;                            // habilidades -> no van aca
      if(CV_NOISE_RX.test(b)) return false;                         // intereses / notas -> no van aca
      return cvIsAchievement(b);
    });
    e.role=cvTrimPiece(e.role); e.company=cvTrimPiece(e.company);
    return e;
  }).filter(function(e){ return e.role || e.company || e.bullets.length; });

  /* EDUCACION: institucion, titulo, ubicacion y fechas. Nada de logros ni skills. */
  m.education=(m.education||[]).filter(function(e){
    var blob=(e.title||'')+' '+(e.detail||'');
    if(CV_CONTACT_RX.test(blob)) return false;
    if(cvIsSkillList(blob)) return false;
    return (CV_INST_RX.test(e.title||'') || CV_DEGREE_RX.test(blob));
  }).map(function(e){
    if(e.detail && CV_VERB_RX.test(e.detail) && e.detail.split(/\s+/).length>9) e.detail='';   // parrafos: fuera
    if(!e.title && e.detail){ e.title=e.detail; e.detail=''; }   // certificaciones sueltas: van como titulo
    return e;
  });

  /* HABILIDADES: terminos, no oraciones ni datos de contacto */
  var seen={};
  m.skills=(m.skills||[]).map(function(k){ return cvTrimPiece(k); })
    .filter(function(k){
      if(!k || k.length<2 || k.length>34) return false;
      if(CV_CONTACT_RX.test(k)) return false;
      if(k.split(/\s+/).length>4) return false;                     // es una frase, no una skill
      if(/^\d+$/.test(k)) return false;
      var key=stripAccents(k.toLowerCase()); if(seen[key]) return false; seen[key]=1;
      return true;
    }).slice(0,20);

  /* INTERESES: ni fechas, ni empresas, ni logros */
  var it=cvTrimPiece(m.interests||'');
  if(CV_CONTACT_RX.test(it) || cvDateOf(it) || (CV_VERB_RX.test(it) && it.split(/\s+/).length>10)) it='';
  m.interests=it;

  /* DATOS PERSONALES: solo email, telefono y links. Ningun curso ni titulo se cuela. */
  m.contactLine=(m.contactLine||'').split(/\s*\|\s*/)
    .map(function(x){ return x.trim(); })
    .filter(function(x){ return x && CV_CONTACT_RX.test(x); })
    .join('  |  ');
  return m;
}

/* --- 2. Modelo vivo + persistencia (el usuario edita, no se pierde) --- */
var CVM=null;
function cvLoadModel(){ try{ var raw=localStorage.getItem('ma_cv'); if(raw){ var m=JSON.parse(raw); if(m && m.edited) CVM=m; } }catch(e){} }
function cvSaveModel(){ try{ if(CVM) localStorage.setItem('ma_cv',JSON.stringify(CVM)); }catch(e){} }
function cvModel(){
  var txt=(document.getElementById('profile').value||'').trim();
  if(!CVM) CVM=cvParse(txt);
  return CVM;
}
function cvInvalidate(){ CVM=null; try{ localStorage.removeItem('ma_cv'); }catch(e){} }   // el CV base cambio
function cvRelang(){
  if(CVM && !CVM.edited && !CVM.translated){ CVM=null; cvModel(); }   // borrador sin tocar: se regenera
  cvApplyLang();                                                       // y el contenido se localiza ES <-> EN
}
/* ---- Deshacer y reiniciar: sin recargar la pagina, sin reiniciar el chat ---- */
var CV_UNDO=[], _cvPending=null;
function cvSnap(){ return CVM? JSON.stringify(CVM) : null; }
function cvPushUndo(snap){
  var sn = snap || cvSnap(); if(!sn) return;
  if(CV_UNDO[CV_UNDO.length-1]===sn) return;
  CV_UNDO.push(sn); if(CV_UNDO.length>40) CV_UNDO.shift();
  cvUpdateUndoBtn();
}
function cvMark(){ _cvPending=cvSnap(); }               // foco en un campo: se guarda el estado previo
function cvCommitPending(){ if(_cvPending){ cvPushUndo(_cvPending); _cvPending=null; } }
function cvUndo(){
  if(!CV_UNDO.length) return;
  var prev=CV_UNDO.pop();
  try{ CVM=JSON.parse(prev); }catch(e){ return; }
  _cvPending=null; cvSaveModel(); renderCVSheet(); cvUpdateUndoBtn();
}
function cvUpdateUndoBtn(){
  var b=document.getElementById('cvUndoBtn'); if(!b) return;
  b.disabled=!CV_UNDO.length; b.style.opacity=CV_UNDO.length?'1':'.4';
  b.style.cursor=CV_UNDO.length?'pointer':'not-allowed';
}
/* vuelve exactamente al borrador que genero la IA a partir del CV base */
function cvReset(){
  cvPushUndo();                                          // el reinicio tambien se puede deshacer
  var txt=(document.getElementById('profile').value||'').trim();
  CVM = txt ? cvParse(txt) : null;
  try{ localStorage.removeItem('ma_cv'); }catch(e){}
  if(CVM){ cvApplyLang(); cvSaveModel(); }
  renderCVSheet();
  var f=document.getElementById('cvEditedFlag'); if(f) f.style.display='none';
  if(typeof toast==='function') toast(t('cv_restored'));
}

/* --- 3. Plantilla editable --- */
/* la edicion manual del CV es una funcion Pro; el plan de entrada descarga el PDF igual */
var cvEditOn=true;
function cvCanEdit(){ return (typeof isPremium==='function') && isPremium() && cvEditOn; }
function cvEd(field,val,cls,ph){
  var on=cvCanEdit();
  return '<span class="'+(cls||'')+'" contenteditable="'+(on?'true':'false')+'" spellcheck="false" data-f="'+field+'" data-ph="'+cvEscape(ph||'')+'">'+cvEscape(val||'')+'</span>';
}
function toggleCvEdit(){
  if(!isPremium()){ if(!isLogged()){ openAuth('login'); return; } openUpgrade(); return; }   // paywall
  cvEditOn=!cvEditOn; renderCVSheet(); renderCvEditBtn();
}
function renderCvEditBtn(){
  var b=document.getElementById('cvEditBtn'); if(!b) return;
  var pro=isPremium();
  b.className='cv-lock-btn'+(pro&&cvEditOn?' cv-edit-on':'');
  b.innerHTML=(pro
    ? '<span class="crown">✎</span>'+(cvEditOn? t('cv_edit_on') : t('cv_edit_off'))
    : '<span class="crown">👑</span>'+t('cv_edit_pro'));
}
function cvSheetHTML(d){
  var e=cvEscape;
  var exp=d.experience.map(function(x,i){
    return '<div class="cv-item" data-exp="'+i+'">'+
      '<button class="cv-x" title="'+e(t('cv_del'))+'" onclick="cvDelExp('+i+')">×</button>'+
      '<div class="cv-row">'+cvEd('exp.'+i+'.role',x.role,'l',t('cv_ph_role'))+cvEd('exp.'+i+'.dates',x.dates,'r',t('cv_ph_dates'))+'</div>'+
      '<div class="cv-row sub">'+cvEd('exp.'+i+'.company',x.company,'l',t('cv_ph_company'))+cvEd('exp.'+i+'.location',x.location||'','r',t('cv_ph_loc'))+'</div>'+
      '<ul class="cv-bul">'+x.bullets.map(function(b,j){
         return '<li>'+cvEd('exp.'+i+'.b.'+j,b,'','…')+'<button class="cv-x" onclick="cvDelBullet('+i+','+j+')">×</button></li>'; }).join('')+'</ul>'+
      '<button class="cv-add" onclick="cvAddBullet('+i+')">+ '+e(t('cv_add_bullet'))+'</button></div>';
  }).join('') || '<p class="cv-p cv-miss">'+e(t('cv_ph_exp'))+'</p>';
  var edu=d.education.map(function(x,i){
    return '<div class="cv-item" data-edu="'+i+'">'+
      '<button class="cv-x" onclick="cvDelEdu('+i+')">×</button>'+
      '<div class="cv-row">'+cvEd('edu.'+i+'.title',x.title,'l',t('cv_ph_inst'))+cvEd('edu.'+i+'.location',x.location||'','r',t('cv_ph_loc'))+'</div>'+
      '<div class="cv-row sub">'+cvEd('edu.'+i+'.detail',x.detail,'l',t('cv_ph_degree'))+cvEd('edu.'+i+'.dates',x.dates,'r',t('cv_ph_dates'))+'</div>'+
    '</div>';
  }).join('') || '<p class="cv-p cv-miss">'+e(t('cv_ph_edu'))+'</p>';
  function sec(k,inner,add){ return '<div class="cv-sec"><hr><div class="cv-h">'+e(t(k))+'</div>'+inner+(add||'')+'</div>'; }
  return '<div class="cv-doc'+(cvCanEdit()?'':' locked')+'" id="cvDoc" oninput="cvSync()" onfocusin="cvMark()">'+
    '<div class="cv-name" contenteditable="true" spellcheck="false" data-f="name" data-ph="'+e(t('cv_ph_name'))+'">'+e(d.name)+'</div>'+
    '<div class="cv-contact" contenteditable="true" spellcheck="false" data-f="contactLine" data-ph="'+e(t('cv_ph_contact'))+'">'+e(d.contactLine)+'</div>'+
    sec('cvh_sum','<p class="cv-p" contenteditable="true" spellcheck="false" data-f="summary" data-ph="'+e(t('cv_ph_sum'))+'">'+e(d.summary)+'</p>')+
    sec('cvh_exp',exp,'<button class="cv-add" onclick="cvAddExp()">+ '+e(t('cv_add_exp'))+'</button>')+
    sec('cvh_edu',edu,'<button class="cv-add" onclick="cvAddEdu()">+ '+e(t('cv_add_edu'))+'</button>')+
    sec('cvh_skl','<p class="cv-p" contenteditable="true" spellcheck="false" data-f="skillsLine" data-ph="'+e(t('cv_ph_skills'))+'">'+e(d.skills.join(' · '))+'</p>')+
    sec('cvh_int','<p class="cv-p" contenteditable="true" spellcheck="false" data-f="interests" data-ph="'+e(t('cv_ph_int'))+'">'+e(d.interests)+'</p>')+
  '</div>';
}
/* lee lo que el usuario escribio en pantalla y lo vuelca al modelo */
function cvSync(silent){
  var doc=document.getElementById('cvDoc'); if(!doc||!CVM) return;
  if(!cvCanEdit()) return;                       // usuario sin Pro: la hoja es de solo lectura
  var v=function(f){ var el=doc.querySelector('[data-f="'+f+'"]'); return el? el.textContent.replace(/\s+/g,' ').trim() : ''; };
  CVM.name=v('name'); CVM.contactLine=v('contactLine'); CVM.summary=v('summary'); CVM.interests=v('interests');
  CVM.skills=v('skillsLine').split(/[·,;|]/).map(function(x){return x.trim();}).filter(Boolean);
  CVM.experience.forEach(function(x,i){ x.role=v('exp.'+i+'.role'); x.company=v('exp.'+i+'.company'); x.dates=v('exp.'+i+'.dates'); x.location=v('exp.'+i+'.location');
    x.bullets=x.bullets.map(function(b,j){ return v('exp.'+i+'.b.'+j); }).filter(function(b){ return b.length>0; }); });
  CVM.education.forEach(function(x,i){ x.title=v('edu.'+i+'.title'); x.detail=v('edu.'+i+'.detail'); x.dates=v('edu.'+i+'.dates'); x.location=v('edu.'+i+'.location'); });
  cvCommitPending();
  CVM.edited=true; CVM.autoSummary=false; CVM.translated=false;
  CVM.baseLang=CVM.viewLang||CVM.baseLang||cvDetectLang(CVM.summary);
  CVM.base=JSON.parse(JSON.stringify({name:CVM.name,contactLine:CVM.contactLine,summary:CVM.summary,
    experience:CVM.experience,education:CVM.education,skills:CVM.skills,interests:CVM.interests}));
  cvSaveModel();
  if(!silent){ var b=document.getElementById('cvEditedFlag'); if(b) b.style.display='inline-flex'; }
}
function renderCVSheet(){ var host=document.getElementById('cvSheetHost'); if(!host) return; host.innerHTML=cvSheetHTML(cvModel()); renderCvEditBtn(); }
function cvAddExp(){ cvPushUndo(); cvSync(true); cvModel().experience.push({role:'',company:'',location:'',dates:'',bullets:['']}); CVM.edited=true; cvSaveModel(); renderCVSheet(); }
function cvAddEdu(){ cvPushUndo(); cvSync(true); cvModel().education.push({title:'',detail:'',location:'',dates:''}); CVM.edited=true; cvSaveModel(); renderCVSheet(); }
function cvAddBullet(i){ cvPushUndo(); cvSync(true); cvModel().experience[i].bullets.push(''); CVM.edited=true; cvSaveModel(); renderCVSheet(); }
function cvDelBullet(i,j){ cvPushUndo(); cvSync(true); cvModel().experience[i].bullets.splice(j,1); CVM.edited=true; cvSaveModel(); renderCVSheet(); }
function cvDelExp(i){ cvPushUndo(); cvSync(true); cvModel().experience.splice(i,1); CVM.edited=true; cvSaveModel(); renderCVSheet(); }
function cvDelEdu(i){ cvPushUndo(); cvSync(true); cvModel().education.splice(i,1); CVM.edited=true; cvSaveModel(); renderCVSheet(); }

function buildImprovedCV(profile){
  var txt=(profile||'').trim();
  if(!txt && !(CVM&&CVM.edited)){ return '<div class="improved"><span class="tape">'+t('imp_tape')+'</span><p style="color:var(--ink-2)">'+t('imp_empty')+'</p></div>'; }
  var d=cvModel();
  var hasNums=/\d+\s*%|[+]\d|(equipo|team|équipe|equipe) de \d/i.test(txt);
  var issues=[];
  if(!hasNums) issues.push(t('imp_i_nums'));
  if(!cvYears(txt)) issues.push(t('imp_i_years'));
  if(d.skills.length<3) issues.push(t('imp_i_skills'));
  issues.push(t('imp_i_target'));
  return '<div class="improved"><span class="tape">'+t('imp_tape')+'</span><h5>'+t('imp_title')+'</h5>'+
    '<div class="cv-sheet-wrap">'+
      '<div class="cv-toolbar"><span class="cv-hint">'+t('cvdoc_note')+'</span>'+
        '<div class="pro-actions"><button class="act-btn" onclick="exportCV(\'pdf\')">⬇ '+t('dl_pdf')+'</button>'+
        '<button class="act-btn" onclick="exportCV(\'docx\')">⬇ '+t('dl_docx')+proLock()+'</button></div></div>'+
      '<div class="cv-editbar">'+(d.translated?'<span class="pill" style="background:rgba(0,113,227,.1);color:var(--blue)">'+t('cv_translated')+'</span>':'')+'<span class="pill" id="cvEditedFlag" style="display:'+(d.edited?'inline-flex':'none')+'">'+t('cv_edited')+'</span>'+
        '<button class="cv-lock-btn" id="cvEditBtn" onclick="toggleCvEdit()"></button>'+
        '<span>'+(isPremium()? t('cv_edit_hint') : t('cv_edit_hint_free'))+'</span>'+
        (isPremium()? '<button class="act-btn cv-btn-sm" id="cvUndoBtn" onclick="cvUndo()" disabled style="opacity:.4;cursor:not-allowed">'+
          '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.1" stroke-linecap="round" stroke-linejoin="round"><path d="M3 7v6h6"/><path d="M3.5 13a9 9 0 1 0 2.1-5.6L3 10"/></svg>'+t('cv_undo')+'</button>'+
        '<button class="act-btn cv-btn-sm" onclick="cvReset()">'+
          '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.1" stroke-linecap="round" stroke-linejoin="round"><path d="M21 2v6h-6"/><path d="M20.5 13a9 9 0 1 1-2.1-5.6L21 10"/></svg>'+t('cv_restore')+'</button>' : '')+'</div>'+
      '<div id="cvSheetHost">'+cvSheetHTML(d)+'</div>'+
    '</div>'+
    '<div class="cvchanges" style="margin-top:18px"><div style="font-size:13px;font-weight:600;color:var(--ink-2);margin-bottom:8px">'+t('imp_changes')+'</div><ul>'+
      issues.map(function(x){return '<li>'+x+'</li>';}).join('')+'</ul></div></div>';
}

/* ============ role ============ */
function renderRole(){ const job=JOBS.filter(function(j){return j.id==document.getElementById('roleSel').value;})[0]||JOBS[0]; const c=jc(job.id);
  function list(items,cls){ return '<ul>'+items.map(function(x){return '<li><span class="b '+cls+'">'+(cls==='val'?'✓':cls==='imp'?'↑':'★')+'</span><span>'+x+'</span></li>';}).join('')+'</ul>'; }
  const qs=c.preguntas.map(function(q){return '<div class="qbox">'+q+'</div>';}).join('');
  document.getElementById('roleBody').innerHTML='<div class="role-grid hover-focus"><div class="role-card"><h5>'+tf('role_val',{role:c.title})+'</h5>'+list(c.valoran,'val')+'</div><div class="role-card"><h5>'+t('role_imp')+'</h5>'+list(c.mejorar,'imp')+'</div><div class="role-card"><h5>'+t('role_prep')+'</h5>'+list(c.prep,'prep')+'<div class="subhead">'+t('role_q')+'</div>'+qs+'</div></div>'+roleExtras(); }

/* ============ apply modal ============ */
function openApply(id){ const job=JOBS.filter(function(j){return j.id===id;})[0]; appliedIds.add(id); selectedIds.delete(id); if(typeof USER!=='undefined'&&USER) recordHistory(job.company, jc(job.id).title); render(); let step=0; drawModal(job,step); clearInterval(fillTimer);
  fillTimer=setInterval(function(){ step++; drawModal(job,step); if(step>=applyFields().length) clearInterval(fillTimer); },360); }
function closeModal(){ clearInterval(fillTimer); clearInterval(apTimer); document.getElementById('modalRoot').innerHTML=''; }
function drawModal(job,step){ const AF=applyFields(); const fields=AF.map(function(f,i){ const fl=i<step; return '<div class="field'+(fl?' filled':'')+'"><span class="fl">'+f.label+'</span><span class="fv">'+(fl?I.check+' '+f.value:'···')+'</span></div>'; }).join('');
  const done=step>=AF.length; const c=jc(job.id);
  const footer=done?'<div class="modal-done"><div class="tick"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6L9 17l-5-5"/></svg></div><p>'+t('apply_done')+'</p><span class="note">'+t('apply_note')+'</span><button class="act-btn" style="margin:0 auto 12px" onclick="coverFor('+job.id+')">'+t('gen_cover')+proLock()+'</button><button class="btn btn-blue block" onclick="closeModal()">'+t('close')+'</button></div>':'<p class="filling-note">'+I.loader+' '+t('filling')+'</p>';
  document.getElementById('modalRoot').innerHTML='<div class="overlay" onclick="if(event.target===this)closeModal()"><div class="modal"><div class="modal-head"><div><div class="m-kick">'+t('apply_kick')+'</div><h3>'+c.title+'</h3><div style="color:var(--ink-2);font-size:14px">'+job.company+'</div></div><button class="xbtn" onclick="closeModal()">'+I.x+'</button></div><p class="modal-sub">'+t('apply_sub')+'</p><div class="fields">'+fields+'</div>'+footer+'</div></div>'; }

/* ============ CV upload (PDF/DOCX) ============ */
if (window.pdfjsLib) { try { pdfjsLib.GlobalWorkerOptions.workerSrc='https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.worker.min.js'; } catch(e){} }
function cvStatus(msg,ok){ const el=document.getElementById('cvStatus'); el.className='cv-status show'+(ok?' ok':''); el.innerHTML=(ok?I.check+' ':(msg===t('cv_reading')?I.loader+' ':''))+msg; }
async function handleCV(input){ const file=input.files&&input.files[0]; if(!file) return; cvStatus(t('cv_reading'),false);
  try {
    let text='';
    if(/\.pdf$/i.test(file.name) && window.pdfjsLib){
      const buf=await file.arrayBuffer(); const pdf=await pdfjsLib.getDocument({data:buf}).promise; const parts=[];
      for(let p=1;p<=pdf.numPages;p++){ const page=await pdf.getPage(p); const c=await page.getTextContent(); parts.push(c.items.map(function(it){return it.str;}).join(' ')); }
      text=parts.join('\n');
    } else if(/\.docx?$/i.test(file.name) && window.mammoth){
      const buf=await file.arrayBuffer(); const res=await mammoth.extractRawText({arrayBuffer:buf}); text=res.value;
    } else { throw new Error('unsupported'); }
    text=(text||'').replace(/[ \t]+/g,' ').replace(/\n{3,}/g,'\n\n').trim();
    if(!text){ throw new Error('empty'); }
    document.getElementById('profile').value=text; renderChips(); cvStatus(t('cv_done'),true);
    if(!document.getElementById('tab-analysis').classList.contains('hidden')) renderAnalysis();
    if(!document.getElementById('tab-adapter').classList.contains('hidden')) renderAdapter();
  } catch(e){ cvStatus(t('cv_err'),false); }
  input.value='';
}

