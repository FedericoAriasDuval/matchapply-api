# =====================================================================
#  Mavante — variables de entorno
#
#  Este archivo es el UNICO que sube a GitHub. No tiene valores reales:
#  tiene los NOMBRES y de donde sacar cada valor.
#
#  Los valores de verdad van en Render -> Environment. Nunca en un archivo.
# =====================================================================

# ---- servidor ----
NODE_ENV=production
PORT=8080
APP_URL=https://mavante.com        # origen del frontend (CORS + links del mail)
COOKIE_DOMAIN=                                  # vacio salvo dominio propio (".mavante.com")

# ---- base de datos (OBLIGATORIA: sin esto el server no arranca) ----
# Neon -> Dashboard -> Connection string -> "Pooled connection"
DATABASE_URL=
# ^ formato: postgresql://USUARIO:PASSWORD@HOST.neon.tech/mavante?sslmode=require
PGSSL=true

# ---- sesiones (OBLIGATORIA: sin esto el server no arranca) ----
# Generar con:  openssl rand -hex 64
JWT_SECRET=
ACCESS_TTL=15m
REFRESH_TTL_DAYS=30

# ---- cifrado de los CVs (opcional, pero deberia estar) ----
# Generar con:  openssl rand -hex 32     <- EXACTAMENTE 32 bytes = 64 caracteres hex
# Si falta: los CVs se guardan en texto plano y el server lo avisa al arrancar.
# OJO: si esta clave se pierde, los CVs ya cifrados NO se pueden recuperar.
CV_ENC_KEY=

# ---- email (verificacion por codigo) — ZOHO MAIL ----
#
# OJO CON LA REGION. Zoho tiene un servidor por centro de datos y NO son
# intercambiables: si tu cuenta esta en Europa y apuntas al de EE.UU., la
# autenticacion falla y no sale un solo mail. Mira la barra de direcciones
# cuando entras a tu Zoho y usa el que corresponda:
#   mail.zoho.com    -> smtp.zoho.com     (EE.UU.)
#   mail.zoho.eu     -> smtp.zoho.eu      (Europa)
#   mail.zoho.in     -> smtp.zoho.in      (India)
#   mail.zoho.com.au -> smtp.zoho.com.au  (Australia)
SMTP_HOST=smtp.zoho.com
# 465 = SSL (lo que usa este codigo: `secure` se activa solo cuando el puerto
# es 465). Si algun dia hay que pasar a 587, ese es STARTTLS.
SMTP_PORT=465
#
# EL USUARIO ES LA DIRECCION COMPLETA, no un alias ni un nombre de cuenta.
SMTP_USER=support@mavante.com
#
# NO es la contrasena con la que entras a Zoho. Con verificacion en dos pasos
# activada (y conviene tenerla), Zoho exige una CONTRASENA DE APLICACION:
#   Zoho Mail -> foto de perfil -> My Account -> Security -> App Passwords ->
#   Generate New Password. Ese valor va aca, y solo se ve una vez.
SMTP_PASS=
#
# El remitente TIENE que ser la misma direccion de SMTP_USER (o un alias que ya
# hayas dado de alta en Zoho). Zoho rechaza con un error 553 cualquier "From"
# que no le pertenezca a la cuenta autenticada: es su forma de evitar que
# alguien mande correo haciendose pasar por otro.
MAIL_FROM="Mavante <support@mavante.com>"
#
# ANTES DE CONFIAR EN ESTO: el dominio mavante.com tiene que estar verificado en
# Zoho con sus registros DNS (SPF y DKIM como minimo). Sin eso los mails salen,
# pero caen en correo no deseado — y un codigo de verificacion en spam es una
# cuenta que nunca se crea. Se configura en Zoho Mail Admin -> Domains.

# ---- IA ----
# console.anthropic.com -> API Keys. Requiere credito cargado.
# Si falta: el server arranca igual, pero /health muestra llm:false.
ANTHROPIC_API_KEY=
LLM_MODEL=claude-sonnet-5
LLM_TIMEOUT_MS=30000
LLM_BREAKER_THRESHOLD=5
LLM_BREAKER_COOLDOWN_MS=30000

# ---- cola de trabajo ----
CV_CONCURRENCY=4
CV_MAX_QUEUE=120
CV_TIMEOUT_MS=45000

# ---- admin (para leer el resumen de resenas) ----
# Generar con:  openssl rand -hex 24
ADMIN_TOKEN=

# ---- pagos (todavia no activos) ----
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO=
